<view class="container">
  <view class="search-section">
    <view class="search-box">
      <t-icon name="search" size="40rpx" color="#60A5FA" />
      <input 
        class="search-input" 
        placeholder="搜索知识卡片 / 知识库"
        placeholder-class="placeholder"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        value="{{searchValue}}"
      />
      <t-icon wx:if="{{searchValue}}" name="close-circle-filled" size="40rpx" color="#BFDBFE" bindtap="clearSearch" />
    </view>
  </view>

  <view class="section hot-section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-bar"></view>
        <text class="section-title">热门卡片</text>
      </view>
      <view class="more-link" bindtap="goToMoreCards">
        <text>查看更多</text>
        <t-icon name="chevron-right" size="28rpx" color="#60A5FA" />
      </view>
    </view>
    <scroll-view class="hot-cards-scroll" scroll-x="true" show-scrollbar="false">
      <view class="hot-cards-list">
        <view 
          class="hot-card {{item.pressed ? 'pressed' : ''}}" 
          wx:for="{{hotCards}}" 
          wx:key="id"
          bindtap="onCardTap"
          bindtouchstart="onCardTouchStart"
          bindtouchend="onCardTouchEnd"
          data-index="{{index}}"
          data-type="hot"
        >
          <view class="hot-card-rank" wx:if="{{index < 3}}">
            <text>{{index + 1}}</text>
          </view>
          <view class="hot-card-content">
            <view class="hot-card-title">{{item.title}}</view>
            <view class="hot-card-tags">
              <t-tag 
                wx:for="{{item.tags}}" 
                wx:for-item="tag" 
                wx:key="*this"
                theme="primary" 
                variant="light"
                size="small"
              >{{tag}}</t-tag>
            </view>
          </view>
          <view class="hot-card-footer">
            <view class="like-count {{item.liked ? 'liked' : ''}}" catchtap="onLikeCard" data-index="{{index}}" data-id="{{item.id}}">
              <t-icon name="{{item.liked ? 'thumb-up-filled' : 'thumb-up'}}" size="24rpx" color="{{item.liked ? '#3B82F6' : '#94A3B8'}}" />
              <text>{{item.likes}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section library-section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-bar"></view>
        <text class="section-title">优质知识库</text>
      </view>
    </view>
    
    <view class="filter-tabs">
      <view class="filter-tabs-inner">
        <view 
          class="filter-tab {{currentSort === 'hot' ? 'active' : ''}}" 
          bindtap="onSortChange"
          data-sort="hot"
        >最热</view>
        <view 
          class="filter-tab {{currentSort === 'new' ? 'active' : ''}}" 
          bindtap="onSortChange"
          data-sort="new"
        >最新</view>
      </view>
    </view>

    <view class="library-grid">
      <view 
        class="library-card {{item.pressed ? 'pressed' : ''}}" 
        wx:for="{{libraries}}" 
        wx:key="id"
        bindtap="onLibraryTap"
        bindtouchstart="onLibraryTouchStart"
        bindtouchend="onLibraryTouchEnd"
        data-index="{{index}}"
      >
        <view class="library-card-left">
          <view class="library-cover">
            <view class="cover-bg cover-{{item.subjectType}}"></view>
            <view class="cover-icon">
              <t-icon name="book" size="44rpx" color="#fff" />
            </view>
          </view>
        </view>
        <view class="library-card-body">
          <text class="library-name">{{item.name}}</text>
          <view class="library-meta">
            <view class="meta-tag meta-{{item.subjectType}}">{{item.subject}}</view>
            <text class="meta-dot">·</text>
            <text class="meta-text">{{item.cardCount}}张卡片</text>
          </view>
        </view>
        <view class="library-card-right">
          <view class="fav-btn {{item.isFavorited ? 'favorited' : ''}}" catchtap="onFavoriteLibrary" data-index="{{index}}" data-id="{{item.id}}">
            <t-icon name="{{item.isFavorited ? 'star-filled' : 'star'}}" size="36rpx" color="{{item.isFavorited ? '#F59E0B' : '#CBD5E1'}}" />
          </view>
          <text class="fav-count">{{item.favorites || 0}}</text>
        </view>
      </view>
    </view>
    
    <view class="empty-state" wx:if="{{libraries.length === 0 && !loading}}">
      <view class="empty-icon">
        <t-icon name="folder-open" size="80rpx" color="#BFDBFE" />
      </view>
      <text class="empty-text">暂无相关知识库</text>
    </view>
  </view>

  <view class="bottom-placeholder"></view>
</view>
