<view class="container">
  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-box">
      <t-icon name="search" size="40rpx" color="#999" />
      <input 
        class="search-input" 
        placeholder="搜索知识卡片 / 知识库" 
        placeholder-class="placeholder"
        bindinput="onSearchInput"
        value="{{searchValue}}"
      />
      <t-icon wx:if="{{searchValue}}" name="close-circle-filled" size="40rpx" color="#ccc" bindtap="clearSearch" />
    </view>
  </view>

  <!-- 热门卡片横向滚动 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门卡片</text>
      <view class="more-link" bindtap="goToMoreCards">
        <text>查看更多</text>
        <t-icon name="chevron-right" size="28rpx" color="#999" />
      </view>
    </view>
    <scroll-view class="hot-cards-scroll" scroll-x="true" show-scrollbar="false">
      <view class="hot-cards-list">
        <view 
          class="hot-card {{item.pressed ? 'pressed' : ''}}" 
          wx:for="{{hotCards}}" 
          wx:key="id"
          bindtap="onCardTap"
          bindtouchstart="onCardTouchStart"
          bindtouchend="onCardTouchEnd"
          data-index="{{index}}"
          data-type="hot"
        >
          <view class="hot-card-content">
            <view class="hot-card-title">{{item.title}}</view>
            <view class="hot-card-tags">
              <t-tag 
                wx:for="{{item.tags}}" 
                wx:for-item="tag" 
                wx:key="*this"
                theme="primary" 
                variant="light"
                size="small"
              >{{tag}}</t-tag>
            </view>
          </view>
          <view class="hot-card-footer">
            <view class="like-count {{item.liked ? 'liked' : ''}}" catchtap="onLikeCard" data-index="{{index}}" data-id="{{item.id}}">
              <t-icon name="{{item.liked ? 'thumb-up-filled' : 'thumb-up'}}" size="24rpx" color="{{item.liked ? '#0052D9' : '#999'}}" />
              <text>{{item.likes}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 优质知识库 -->
  <view class="section library-section">
    <view class="section-header">
      <text class="section-title">优质知识库</text>
      <view class="filter-tabs">
        <view 
          class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" 
          bindtap="onFilterChange"
          data-filter="all"
        >全部</view>
        <view 
          class="filter-tab {{currentFilter === 'civil' ? 'active' : ''}}" 
          bindtap="onFilterChange"
          data-filter="civil"
        >民法</view>
        <view 
          class="filter-tab {{currentFilter === 'criminal' ? 'active' : ''}}" 
          bindtap="onFilterChange"
          data-filter="criminal"
        >刑法</view>
      </view>
    </view>
    <view class="library-grid">
      <view 
        class="library-card {{item.pressed ? 'pressed' : ''}}" 
        wx:for="{{libraries}}" 
        wx:key="id"
        bindtap="onLibraryTap"
        bindtouchstart="onLibraryTouchStart"
        bindtouchend="onLibraryTouchEnd"
        data-index="{{index}}"
      >
        <view class="library-card-header">
          <view class="library-icon">
            <t-icon name="folder" size="48rpx" color="#0052D9" />
          </view>
        </view>
        <view class="library-card-body">
          <text class="library-name">{{item.name}}</text>
          <view class="library-tags">
            <t-tag theme="primary" variant="light" size="small">{{item.subject}}</t-tag>
          </view>
        </view>
        <view class="library-card-footer">
          <view class="stat-item">
            <t-icon name="file" size="28rpx" color="#999" />
            <text>{{item.cardCount}}张卡片</text>
          </view>
          <view class="stat-item fav-stat {{item.isFavorited ? 'favorited' : ''}}" catchtap="onFavoriteLibrary" data-index="{{index}}" data-id="{{item.id}}">
            <t-icon name="{{item.isFavorited ? 'star-filled' : 'star'}}" size="28rpx" color="{{item.isFavorited ? '#FAAD14' : '#999'}}" />
            <text class="fav-text">{{item.favorites || 0}}收藏</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>
</view>
