.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.search-section {
  padding: 24rpx 28rpx 0;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #F8FAFC;
  border-radius: 48rpx;
  padding: 20rpx 28rpx;
  gap: 16rpx;
  border: 2rpx solid #E2E8F0;
  transition: all 0.3s ease;
}

.search-box:focus-within {
  border-color: #60A5FA;
  background-color: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(96, 165, 250, 0.15);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1E293B;
  height: 48rpx;
}

.placeholder {
  color: #94A3B8;
  font-size: 28rpx;
}

.section {
  margin-top: 32rpx;
  padding: 0 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #3B82F6 0%, #60A5FA 100%);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E293B;
  letter-spacing: 0.5rpx;
}

.more-link {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #3B82F6;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: rgba(59, 130, 246, 0.06);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.more-link:active {
  background: rgba(59, 130, 246, 0.12);
}

.filter-tabs {
  margin-bottom: 24rpx;
}

.filter-tabs-inner {
  display: flex;
  gap: 20rpx;
}

.filter-tab {
  font-size: 24rpx;
  font-weight: 400;
  color: #64748B;
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
  background-color: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  transition: all 0.25s ease;
}

.filter-tab.active {
  color: #fff;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-color: transparent;
  font-weight: 550;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.25);
}

.hot-cards-scroll {
  white-space: nowrap;
  margin: 0 -28rpx;
  padding: 0 28rpx;
}

.hot-cards-list {
  display: flex;
  gap: 20rpx;
  padding: 8rpx 0;
}

.hot-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  width: 240rpx;
  height: 260rpx;
  background: linear-gradient(145deg, #FFFFFF 0%, #F8FAFF 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(59, 130, 246, 0.06);
  border: 2rpx solid #E2E8F0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.hot-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #3B82F6 0%, #60A5FA 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.hot-card:active::before,
.hot-card.pressed::before {
  opacity: 1;
}

.hot-card.pressed {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(59, 130, 246, 0.1);
}

.hot-card-rank {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
}

.hot-card-rank text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.hot-card-content {
  flex: 1;
  padding-top: 8rpx;
}

.hot-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  white-space: normal;
}

.hot-card-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.hot-card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.like-count {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #94A3B8;
  padding: 10rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(148, 163, 184, 0.08);
  transition: all 0.25s ease;
}

.like-count.liked {
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.08);
}

.like-count:active {
  transform: scale(0.92);
}

.library-section {
  padding-bottom: 24rpx;
}

.library-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.library-card {
  width: 100%;
  box-sizing: border-box;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(59, 130, 246, 0.05);
  border: 2rpx solid #E2E8F0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.library-card.pressed {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(59, 130, 246, 0.08);
}

.library-card-left {
  flex-shrink: 0;
}

.library-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.cover-bg {
  position: absolute;
  inset: 0;
}

.cover-bg.cover-civil {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
}

.cover-bg.cover-criminal {
  background: linear-gradient(135deg, #EF4444 0%, #F87171 100%);
}

.cover-bg.cover-constitution {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
}

.cover-bg.cover-admin {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
}

.cover-bg.cover-default {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
}

.cover-icon {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.library-card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.library-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.library-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.meta-tag.meta-civil {
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.08);
}

.meta-tag.meta-criminal {
  color: #EF4444;
  background: rgba(239, 68, 68, 0.08);
}

.meta-tag.meta-constitution {
  color: #8B5CF6;
  background: rgba(139, 92, 246, 0.08);
}

.meta-tag.meta-admin {
  color: #10B981;
  background: rgba(16, 185, 129, 0.08);
}

.meta-tag.meta-default {
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.08);
}

.meta-dot {
  color: #CBD5E1;
  font-size: 20rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #64748B;
}

.library-card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0rpx;
  flex-shrink: 0;
  margin-right: 8rpx;
  margin-top: -8rpx;
}

.fav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  transition: all 0.25s ease;
}

.fav-btn.favorited {
  background: transparent;
}

.fav-btn:active {
  transform: scale(0.9);
}

.fav-count {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: -8rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 20rpx;
}

.empty-icon {
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

.bottom-placeholder {
  height: 48rpx;
}
