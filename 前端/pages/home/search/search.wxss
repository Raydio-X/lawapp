.container {
  min-height: 100vh;
  background-color: #f5f6fa;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
  gap: 16rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f6fa;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 44rpx;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

.cancel-btn {
  font-size: 28rpx;
  color: #3B82F6;
  white-space: nowrap;
  padding: 8rpx 4rpx;
}

.search-body {
  padding-bottom: env(safe-area-inset-bottom);
}

.search-tabs {
  background-color: #fff;
}

.result-count {
  font-size: 24rpx;
  color: #999;
  padding: 16rpx 32rpx;
}

.card-item {
  background-color: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-main {
  margin-bottom: 16rpx;
}

.card-question {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.card-answer {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.highlight-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  height: 40rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
  background-color: #e8f4ff;
  color: #3B82F6;
  flex-shrink: 0;
  padding: 0 8rpx;
  margin-top: 6rpx;
}

.answer-tag {
  background-color: #e8f8e8;
  color: #2ba471;
}

.card-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  flex: 1;
}

.answer-text {
  color: #666;
  font-size: 26rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.meta-divider {
  font-size: 22rpx;
  color: #ddd;
}

.card-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.lib-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  margin: 0 24rpx 12rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.lib-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e8f4ff;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.lib-info {
  flex: 1;
  min-width: 0;
}

.lib-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lib-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.lib-subject {
  font-size: 22rpx;
  color: #3B82F6;
  background-color: #e8f4ff;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.lib-count {
  font-size: 22rpx;
  color: #999;
}

.lib-arrow {
  flex-shrink: 0;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-wrap {
  padding: 120rpx 0;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: #3B82F6;
}

.no-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #ccc;
}

.search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  gap: 24rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

.highlight-text {
  background-color: #ffef66;
  border-radius: 4rpx;
  padding: 0 4rpx;
}
