var highlight = function(text, keyword) {
  if (!text || !keyword) {
    return text || '';
  }
  
  keyword = keyword.trim();
  if (keyword.length === 0) {
    return text;
  }
  
  var lowerText = text.toLowerCase();
  var lowerKeyword = keyword.toLowerCase();
  var result = [];
  var lastIndex = 0;
  var index = lowerText.indexOf(lowerKeyword);
  
  while (index !== -1) {
    if (index > lastIndex) {
      result.push(text.substring(lastIndex, index));
    }
    result.push('【' + text.substring(index, index + keyword.length) + '】');
    lastIndex = index + keyword.length;
    index = lowerText.indexOf(lowerKeyword, lastIndex);
  }
  
  if (lastIndex < text.length) {
    result.push(text.substring(lastIndex));
  }
  
  return result.join('');
};

var isHighlight = function(text) {
  if (!text) return false;
  return text.indexOf('【') === 0 && text.indexOf('】') === text.length - 1;
};

var getHighlightText = function(text) {
  if (!text) return '';
  if (text.indexOf('【') === 0 && text.indexOf('】') === text.length - 1) {
    return text.substring(1, text.length - 1);
  }
  return text;
};

var splitHighlight = function(text, keyword) {
  if (!text || !keyword) {
    return [{ text: text || '', highlight: false }];
  }
  
  keyword = keyword.trim();
  if (keyword.length === 0) {
    return [{ text: text, highlight: false }];
  }
  
  var lowerText = text.toLowerCase();
  var lowerKeyword = keyword.toLowerCase();
  var result = [];
  var lastIndex = 0;
  var index = lowerText.indexOf(lowerKeyword);
  
  while (index !== -1) {
    if (index > lastIndex) {
      result.push({ text: text.substring(lastIndex, index), highlight: false });
    }
    result.push({ text: text.substring(index, index + keyword.length), highlight: true });
    lastIndex = index + keyword.length;
    index = lowerText.indexOf(lowerKeyword, lastIndex);
  }
  
  if (lastIndex < text.length) {
    result.push({ text: text.substring(lastIndex), highlight: false });
  }
  
  return result.length > 0 ? result : [{ text: text, highlight: false }];
};

module.exports = {
  highlight: highlight,
  isHighlight: isHighlight,
  getHighlightText: getHighlightText,
  splitHighlight: splitHighlight
};
