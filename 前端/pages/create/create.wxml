<wxs module="utils">
module.exports = {
  contains: function(arr, val) {
    if (!arr || !arr.length) return false;
    for (var i = 0; i < arr.length; i++) {
      if (arr[i] === val) return true;
    }
    return false;
  },
  getLevelText: function(level) {
    if (level === 0) return '';
    return level + '级';
  }
}
</wxs>

<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">创建</text>
    <text class="page-subtitle">开始记录你的知识</text>
  </view>

  <!-- 创建入口卡片 -->
  <view class="create-section">
    <view 
      class="create-card {{libraryPressed ? 'pressed' : ''}}" 
      bindtap="onCreateLibrary"
      bindtouchstart="onLibraryTouchStart"
      bindtouchend="onLibraryTouchEnd"
    >
      <view class="create-card-icon library-icon">
        <t-icon name="folder" size="56rpx" color="#fff" />
      </view>
      <view class="create-card-content">
        <text class="create-card-title">创建知识库</text>
        <text class="create-card-desc">搭建你的专属背诵体系</text>
      </view>
      <view class="create-card-arrow">
        <t-icon name="chevron-right" size="40rpx" color="#ccc" />
      </view>
    </view>

    <view 
      class="create-card {{cardPressed ? 'pressed' : ''}}" 
      bindtap="onCreateCard"
      bindtouchstart="onCardTouchStart"
      bindtouchend="onCardTouchEnd"
    >
      <view class="create-card-icon card-icon">
        <t-icon name="edit" size="56rpx" color="#fff" />
      </view>
      <view class="create-card-content">
        <text class="create-card-title">新增背诵卡片</text>
        <text class="create-card-desc">记录一个知识点</text>
      </view>
      <view class="create-card-arrow">
        <t-icon name="chevron-right" size="40rpx" color="#ccc" />
      </view>
    </view>
  </view>

  <!-- 快速操作区 -->
  <view class="quick-actions">
    <view class="quick-action-title">快捷工具</view>
    <view class="quick-action-grid">
      <view class="quick-action-item {{smartImportDisabled ? 'disabled' : ''}}" bindtap="onSmartImport">
        <view class="quick-action-icon smart-icon">
          <t-icon name="bulletpoint" size="40rpx" color="{{smartImportDisabled ? '#ccc' : '#0052D9'}}" />
        </view>
        <text class="quick-action-text">智能导入</text>
        <view class="coming-soon-tag" wx:if="{{smartImportDisabled}}">即将开放</view>
      </view>
      <view class="quick-action-item" bindtap="onBatchImport">
        <view class="quick-action-icon batch-icon">
          <t-icon name="upload" size="40rpx" color="#00A870" />
        </view>
        <text class="quick-action-text">批量导入</text>
      </view>
    </view>
  </view>

  <!-- 我的知识库 -->
  <view class="my-libraries-section">
    <view class="section-header">
      <text class="section-title">我的知识库</text>
      <text class="manage-btn {{isManageMode ? 'active' : ''}}" bindtap="onManageLibraries">{{isManageMode ? '取消' : '管理'}}</text>
    </view>
    <view class="library-list" wx:if="{{myLibraries.length > 0}}">
      <view 
        class="library-item {{item.pressed ? 'pressed' : ''}} {{isManageMode ? 'manage-mode' : ''}}" 
        wx:for="{{myLibraries}}" 
        wx:key="id"
        bindtap="onLibraryItemTap"
        bindtouchstart="onLibraryItemTouchStart"
        bindtouchend="onLibraryItemTouchEnd"
        data-index="{{index}}"
      >
        <view class="library-item-icon">
          <t-icon name="folder" size="48rpx" color="#0052D9" />
        </view>
        <view class="library-item-content">
          <text class="library-item-name">{{item.name}}</text>
          <view class="library-item-meta">
            <text class="meta-item">{{item.subject}}</text>
            <text class="meta-dot">·</text>
            <text class="meta-item">{{item.cardCount}}张卡片</text>
          </view>
        </view>
        <view class="library-item-delete" wx:if="{{isDeleteMode}}" catchtap="onDeleteLibrary" data-id="{{item.id}}" data-index="{{index}}">
          <text class="delete-text">删除</text>
        </view>
        <view class="library-item-actions" wx:elif="{{isManageMode}}">
          <text class="action-text edit" catchtap="onEditOutline" data-id="{{item.id}}" data-index="{{index}}">编辑</text>
          <text class="action-text delete" catchtap="onDeleteLibrary" data-id="{{item.id}}" data-index="{{index}}">删除</text>
        </view>
        <view class="library-item-arrow" wx:else>
          <t-icon name="chevron-right" size="32rpx" color="#ccc" />
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <t-icon name="folder" size="80rpx" color="#ddd" />
      <text class="empty-text">还没有创建知识库</text>
      <text class="empty-subtext">点击上方"创建知识库"开始创建</text>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>
</view>

<!-- 编辑弹窗 -->
<t-popup 
  visible="{{showOutlinePopup}}" 
  bind:visible-change="onOutlinePopupChange"
  placement="bottom"
  close-on-overlay-click="{{true}}"
>
  <view class="edit-popup">
    <view class="edit-disable-mask" wx:if="{{showDeleteConfirm || showDeleteCardConfirm}}" catchtouchmove="preventTouchMove"></view>
    <view class="edit-popup-header">
      <text class="edit-popup-title">编辑</text>
      <view class="edit-popup-done" bindtap="onCloseOutlinePopup">
        <text>完成</text>
      </view>
    </view>

    <!-- Tab 切换 -->
    <view class="edit-tabs">
      <view class="edit-tab {{editTab === 'info' ? 'active' : ''}}" bindtap="onSwitchEditTab" data-tab="info">基本信息</view>
      <view class="edit-tab {{editTab === 'outline' ? 'active' : ''}}" bindtap="onSwitchEditTab" data-tab="outline">大纲管理</view>
      <view class="edit-tab {{editTab === 'cards' ? 'active' : ''}}" bindtap="onSwitchEditTab" data-tab="cards">卡片管理</view>
    </view>

    <!-- 基本信息 Tab -->
    <view class="edit-content" wx:if="{{editTab === 'info'}}">
      <view class="edit-info-section">
        <view class="edit-info-item">
          <text class="edit-info-label">知识库名称</text>
          <input 
            class="edit-info-input" 
            value="{{editLibraryName}}" 
            bindinput="onLibraryNameInput" 
            placeholder="请输入知识库名称"
            maxlength="20"
          />
        </view>
        <view class="edit-info-item">
          <text class="edit-info-label">卡片数量</text>
          <text class="edit-info-value">{{currentLibrary.cardCount || 0}} 张</text>
        </view>
      </view>
      <view class="edit-info-save-btn" bindtap="onSaveLibraryName">
        <text>保存修改</text>
      </view>
    </view>

    <!-- 大纲管理 Tab -->
    <view class="edit-content" wx:if="{{editTab === 'outline'}}">
      <view class="outline-container">
        <view class="outline-list" wx:if="{{outline.length > 0}}">
          <view 
            class="outline-item {{item.level > 1 ? 'sub-item' : ''}} {{dragIndex === index ? 'dragging' : ''}}"
            wx:for="{{outline}}" 
            wx:key="id"
            data-index="{{index}}"
            data-level="{{item.level}}"
            bindtouchstart="onTouchStart"
            catchtouchmove="onTouchMove"
            bindtouchend="onTouchEnd"
          >
            <view class="outline-drag-handle">
              <t-icon name="move" size="32rpx" color="#ccc" />
            </view>
            <view class="outline-main outline-level-{{item.level}}">
              <view class="outline-level-indicator">
                <text>{{item.level}}级</text>
              </view>
              <view class="outline-content">
                <input 
                  class="outline-input" 
                  value="{{item.title}}" 
                  bindinput="onOutlineInput" 
                  data-index="{{index}}"
                  placeholder="输入标题"
                  maxlength="100"
                />
              </view>
            </view>
            <view class="outline-actions">
              <view class="action-btn" catchtap="onDeleteOutline" data-index="{{index}}">
                <t-icon name="close" size="36rpx" color="#999" />
              </view>
            </view>
          </view>
        </view>

        <view class="outline-empty" wx:else>
          <t-icon name="folder" size="64rpx" color="#ddd" />
          <text>暂无大纲，点击下方按钮添加</text>
        </view>

        <view class="outline-add-btn" bindtap="onAddOutline">
          <t-icon name="add" size="36rpx" color="#0052D9" />
          <text>添加标题</text>
        </view>
      </view>

      <view class="outline-tips">
        <text>提示：长按拖动可排序，左右滑动可改变标题层级</text>
      </view>
    </view>

    <!-- 卡片管理 Tab -->
    <view class="edit-content" wx:if="{{editTab === 'cards'}}">
      <view class="cards-manage-container">
        <!-- 批量操作工具栏 -->
        <view class="cards-manage-toolbar" wx:if="{{editCards.length > 0}}">
          <view class="toolbar-left">
            <view class="batch-toggle-btn {{isBatchSelectMode ? 'active' : ''}}" bindtap="onToggleBatchSelect">
              <t-icon name="{{isBatchSelectMode ? 'check' : 'check-circle'}}" size="32rpx" color="{{isBatchSelectMode ? '#0052D9' : '#666'}}" />
              <text>{{isBatchSelectMode ? '取消选择' : '批量管理'}}</text>
            </view>
          </view>
          <view class="toolbar-right" wx:if="{{isBatchSelectMode}}">
            <view class="select-all-btn" bindtap="onSelectAllCards">
              <text>{{selectedCardIds.length === editCards.length ? '取消全选' : '全选'}}</text>
            </view>
            <view class="move-btn {{selectedCardIds.length > 0 ? '' : 'disabled'}}" bindtap="onShowChapterPicker">
              <t-icon name="folder-move" size="32rpx" color="{{selectedCardIds.length > 0 ? '#0052D9' : '#ccc'}}" />
              <text>移动到章节</text>
            </view>
          </view>
        </view>

        <!-- 已选择数量提示 -->
        <view class="selected-count-bar" wx:if="{{isBatchSelectMode && selectedCardIds.length > 0}}">
          <text>已选择 {{selectedCardIds.length}} 张卡片</text>
        </view>

        <view class="cards-manage-list" wx:if="{{editCards.length > 0}}">
          <view 
            class="cards-manage-item {{isBatchSelectMode && utils.contains(selectedCardIds, item.id) ? 'selected' : ''}}"
            wx:for="{{editCards}}" 
            wx:key="id"
          >
            <view class="cards-manage-info" bindtap="{{isBatchSelectMode ? 'onSelectCard' : 'onEditCard'}}" data-id="{{item.id}}" data-index="{{index}}">
              <view class="cards-manage-title">{{item.question}}</view>
              <view class="cards-manage-chapter" wx:if="{{item.chapterName}}">{{item.chapterName}}</view>
            </view>
            <view class="cards-manage-actions" wx:if="{{!isBatchSelectMode}}">
              <view class="cards-manage-btn edit" catchtap="onEditCard" data-id="{{item.id}}" data-index="{{index}}">
                <t-icon name="edit" size="36rpx" color="#0052D9" />
              </view>
              <view class="cards-manage-btn delete" catchtap="onDeleteCard" data-id="{{item.id}}" data-index="{{index}}">
                <t-icon name="delete" size="36rpx" color="#e34d59" />
              </view>
            </view>
          </view>
        </view>

        <view class="cards-manage-empty" wx:else>
          <t-icon name="file" size="64rpx" color="#ddd" />
          <text>暂无卡片</text>
        </view>

        <view class="cards-manage-add-btn" bindtap="onAddCard" wx:if="{{!isBatchSelectMode}}">
          <t-icon name="add" size="36rpx" color="#0052D9" />
          <text>添加卡片</text>
        </view>
      </view>
    </view>
  </view>
</t-popup>

<!-- 章节选择弹窗 -->
<t-popup 
  visible="{{showChapterPicker}}" 
  bind:visible-change="onCloseChapterPicker"
  placement="bottom"
>
  <view class="chapter-picker-popup">
    <view class="chapter-picker-header">
      <text class="chapter-picker-title">选择目标章节</text>
      <view class="chapter-picker-close" bindtap="onCloseChapterPicker">
        <t-icon name="close" size="40rpx" color="#999" />
      </view>
    </view>
    <view class="chapter-picker-list">
      <view 
        class="chapter-picker-item {{targetChapterId === item.id ? 'selected' : ''}}"
        wx:for="{{chapterPickerList}}" 
        wx:key="id"
        bindtap="onSelectChapter"
        data-id="{{item.id}}"
      >
        <view class="chapter-picker-name" style="padding-left: {{item.level * 20}}rpx;">
          <view class="chapter-level-indicator" wx:if="{{item.level > 0}}">
            <text>{{utils.getLevelText(item.level)}}</text>
          </view>
          <text>{{item.name}}</text>
        </view>
        <t-icon wx:if="{{targetChapterId === item.id}}" name="check" size="36rpx" color="#0052D9" />
      </view>
    </view>
    <view class="chapter-picker-footer">
      <view class="chapter-picker-btn cancel" bindtap="onCloseChapterPicker">取消</view>
      <view class="chapter-picker-btn confirm" bindtap="onConfirmMoveCards">确认移动</view>
    </view>
  </view>
</t-popup>

<!-- 删除卡片确认弹窗 -->
<t-popup 
  visible="{{showDeleteCardConfirm}}" 
  bind:visible-change="onDeleteCardConfirmChange"
  placement="center"
  close-on-overlay-click="{{false}}"
>
  <view class="delete-confirm-popup">
    <view class="delete-confirm-title">删除确认</view>
    <view class="delete-confirm-content">
      <text>确定要删除这张卡片吗？此操作不可恢复。</text>
    </view>
    <view class="delete-confirm-actions">
      <view class="delete-btn cancel" bindtap="onCancelDeleteCard">取消</view>
      <view class="delete-btn confirm" bindtap="onConfirmDeleteCard">删除</view>
    </view>
  </view>
</t-popup>

<!-- 删除确认弹窗 -->
<t-popup 
  visible="{{showDeleteConfirm}}" 
  bind:visible-change="onDeleteConfirmChange"
  placement="center"
  close-on-overlay-click="{{false}}"
>
  <view class="delete-confirm-popup">
    <view class="delete-confirm-title">删除确认</view>
    <view class="delete-confirm-content">
      <text>确定要删除"{{deleteItem.title || '此标题'}}"吗？{{deleteItem.childCount > 0 ? '将同时删除其下的 ' + deleteItem.childCount + ' 个子标题，' : ''}}该标题下的卡片也将被删除，此操作不可恢复。</text>
    </view>
    <view class="delete-confirm-actions">
      <view class="delete-btn cancel" bindtap="onCancelDelete">取消</view>
      <view class="delete-btn confirm" bindtap="onConfirmDelete">删除</view>
    </view>
  </view>
</t-popup>

<!-- 删除知识库确认弹窗 -->
<t-popup 
  visible="{{showDeleteLibraryConfirm}}" 
  bind:visible-change="onDeleteLibraryConfirmChange"
  placement="center"
  close-on-overlay-click="{{false}}"
>
  <view class="delete-confirm-popup">
    <view class="delete-confirm-title">删除确认</view>
    <view class="delete-confirm-content">
      <text>确定要删除知识库"{{deleteLibraryItem.name}}"吗？该知识库包含的 {{deleteLibraryItem.cardCount}} 张卡片也将被删除，此操作不可恢复。</text>
    </view>
    <view class="delete-confirm-actions">
      <view class="delete-btn cancel" bindtap="onCancelDeleteLibrary">取消</view>
      <view class="delete-btn confirm" bindtap="onConfirmDeleteLibrary">删除</view>
    </view>
  </view>
</t-popup>

<!-- 批量导入弹窗 -->
<view class="batch-popup" wx:if="{{showBatchImport}}" bindtap="onCloseBatchImport">
  <view class="batch-container" catchtap="preventTouchMove">
    <view class="batch-header">
      <text class="batch-title">批量导入</text>
      <view class="batch-close" bindtap="onCloseBatchImport">
        <t-icon name="close" size="32rpx" color="#999" />
      </view>
    </view>

    <!-- 步骤1: 选择知识库 -->
    <view class="batch-step" wx:if="{{batchStep === 1}}">
      <view class="batch-step-header">
        <text class="batch-step-num">1</text>
        <text class="batch-step-title">选择目标知识库</text>
      </view>
      <view class="batch-library-list">
        <view 
          class="batch-library-item {{batchLibraryId === item.id ? 'selected' : ''}}" 
          wx:for="{{myLibraries}}" 
          wx:key="id"
          bindtap="onSelectBatchLibrary"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
        >
          <view class="batch-library-radio">
            <view class="batch-radio-dot" wx:if="{{batchLibraryId === item.id}}"></view>
          </view>
          <view class="batch-library-info">
            <text class="batch-library-name">{{item.name}}</text>
            <text class="batch-library-count">{{item.cardCount}}张卡片</text>
          </view>
        </view>
      </view>
      <view class="batch-empty" wx:if="{{myLibraries.length === 0}}">
        <text>请先创建知识库</text>
      </view>
      <view class="batch-step-footer">
        <view class="batch-next-btn {{!batchLibraryId ? 'disabled' : ''}}" bindtap="onBatchNext">下一步</view>
      </view>
    </view>

    <!-- 步骤2: 上传文件 -->
    <view class="batch-step" wx:if="{{batchStep === 2}}">
      <view class="batch-step-header">
        <text class="batch-step-num">2</text>
        <text class="batch-step-title">上传Excel文件</text>
      </view>
      
      <view class="batch-upload-area" bindtap="onChooseFile">
        <view class="batch-upload-content" wx:if="{{!batchFileName}}">
          <t-icon name="upload" size="64rpx" color="#00A870" />
          <text class="batch-upload-text">点击选择Excel文件</text>
          <text class="batch-upload-hint">支持 .xlsx / .xls 格式</text>
        </view>
        <view class="batch-upload-done" wx:else>
          <t-icon name="file" size="48rpx" color="#00A870" />
          <text class="batch-file-name">{{batchFileName}}</text>
          <text class="batch-file-change">点击更换文件</text>
        </view>
      </view>

      <view class="batch-template-section">
        <view class="batch-template-title">
          <t-icon name="info-circle" size="28rpx" color="#999" />
          <text>模板格式说明</text>
        </view>
        <view class="batch-template-info">
          <text class="batch-template-row"><text class="col-a">A列</text><text class="col-b">问题</text></text>
          <text class="batch-template-row"><text class="col-a">B列</text><text class="col-b">答案</text></text>
          <text class="batch-template-row"><text class="col-a">C列(可选)</text><text class="col-b">章节</text></text>
        </view>
        <view class="batch-download-template" bindtap="onDownloadTemplate">
          <t-icon name="download" size="28rpx" color="#0052D9" />
          <text>下载模板</text>
        </view>
      </view>

      <view class="batch-step-actions">
        <view class="batch-prev-btn" bindtap="onBatchPrev">上一步</view>
        <view class="batch-next-btn {{!batchFileName ? 'disabled' : ''}}" bindtap="onBatchParse">解析文件</view>
      </view>
    </view>

    <!-- 步骤3: 预览确认 -->
    <view class="batch-step" wx:if="{{batchStep === 3}}">
      <view class="batch-step-header">
        <text class="batch-step-num">3</text>
        <text class="batch-step-title">预览并确认</text>
      </view>

      <view class="batch-preview-summary">
        <text class="batch-preview-total">共解析到 <text class="highlight">{{batchCards.length}}</text> 张卡片</text>
      </view>

      <scroll-view class="batch-preview-list" scroll-y>
        <view class="batch-preview-item" wx:for="{{batchCards}}" wx:key="index">
          <view class="batch-preview-index">{{index + 1}}</view>
          <view class="batch-preview-content">
            <text class="batch-preview-q">Q: {{item.question}}</text>
            <text class="batch-preview-a">A: {{item.answer}}</text>
            <text class="batch-preview-chapter" wx:if="{{item.chapter}}">{{item.chapter}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="batch-step-actions">
        <view class="batch-prev-btn" bindtap="onBatchPrev">上一步</view>
        <view class="batch-next-btn {{batchImporting ? 'disabled' : ''}}" bindtap="onBatchConfirmImport">
          {{batchImporting ? '导入中...' : '确认导入'}}
        </view>
      </view>
    </view>

    <!-- 步骤4: 导入结果 -->
    <view class="batch-step" wx:if="{{batchStep === 4}}">
      <view class="batch-result">
        <view class="batch-result-icon">
          <t-icon name="{{batchImportSuccess ? 'check-circle' : 'error-circle'}}" size="96rpx" color="{{batchImportSuccess ? '#00A870' : '#E34D59'}}" />
        </view>
        <text class="batch-result-title">{{batchImportSuccess ? '导入成功' : '导入失败'}}</text>
        <text class="batch-result-desc" wx:if="{{batchImportSuccess}}">成功导入 {{batchImportCount}} 张卡片</text>
        <text class="batch-result-desc" wx:else>{{batchImportError || '请检查文件格式后重试'}}</text>
      </view>
      <view class="batch-step-footer">
        <view class="batch-next-btn" bindtap="onCloseBatchImport">完成</view>
      </view>
    </view>
  </view>
</view>
