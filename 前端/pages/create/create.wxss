.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 120rpx;
}

/* 页面标题 */
.page-header {
  padding: 48rpx 32rpx 32rpx;
  background: #fff;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #64748B;
}

/* 创建入口卡片 */
.create-section {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.create-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.create-card.pressed {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.create-card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.create-card-icon.library-icon {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
}

.create-card-icon.card-icon {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
}

.create-card-content {
  flex: 1;
  min-width: 0;
}

.create-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
}

.create-card-desc {
  font-size: 26rpx;
  color: #64748B;
  display: block;
}

.create-card-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 快速操作区 */
.quick-actions {
  padding: 32rpx;
  margin-top: 16rpx;
}

.quick-action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 20rpx;
}

.quick-action-grid {
  display: flex;
  gap: 20rpx;
}

.quick-action-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.quick-action-item.disabled {
  opacity: 0.6;
}

.quick-action-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.quick-action-icon.smart-icon {
  background: rgba(59, 130, 246, 0.1);
}

.quick-action-icon.batch-icon {
  background: rgba(0, 168, 112, 0.1);
}

.quick-action-text {
  font-size: 26rpx;
  color: #1E293B;
  font-weight: 500;
}

.coming-soon-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 20rpx;
  color: #F59E0B;
  background: rgba(245, 158, 11, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 我的知识库 */
.my-libraries-section {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.manage-btn {
  font-size: 26rpx;
  color: #3B82F6;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(59, 130, 246, 0.08);
}

.manage-btn.active {
  background: #3B82F6;
  color: #fff;
}

.library-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.library-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.library-item.pressed {
  transform: scale(0.98);
}

.library-item.manage-mode {
  padding-right: 16rpx;
}

.library-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: rgba(59, 130, 246, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.library-item-content {
  flex: 1;
  min-width: 0;
}

.library-item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.library-item-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #64748B;
}

.meta-item {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-dot {
  margin: 0 8rpx;
  color: #CBD5E1;
}

.library-item-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.library-item-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-text {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.action-text.edit {
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.08);
}

.action-text.delete {
  color: #E34D59;
  background: rgba(227, 77, 89, 0.08);
}

.library-item-delete {
  flex-shrink: 0;
}

.delete-text {
  font-size: 26rpx;
  color: #fff;
  background: #E34D59;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748B;
  margin-top: 20rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

/* 底部占位 */
.bottom-placeholder {
  height: 40rpx;
}

/* 编辑弹窗 */
.edit-popup {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.edit-disable-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.edit-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E7E7E7;
  flex-shrink: 0;
}

.edit-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.edit-popup-done {
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 500;
}

/* Tab 切换 */
.edit-tabs {
  display: flex;
  border-bottom: 1rpx solid #E7E7E7;
  flex-shrink: 0;
}

.edit-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #64748B;
  position: relative;
}

.edit-tab.active {
  color: #3B82F6;
  font-weight: 500;
}

.edit-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #3B82F6;
  border-radius: 2rpx;
}

/* 编辑内容 */
.edit-content {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}

/* 基本信息Tab */
.edit-info-section {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
}

.edit-info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E7E7E7;
}

.edit-info-item:last-child {
  border-bottom: none;
}

.edit-info-label {
  font-size: 28rpx;
  color: #64748B;
}

.edit-info-input {
  font-size: 28rpx;
  color: #1E293B;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
}

.edit-info-value {
  font-size: 28rpx;
  color: #1E293B;
}

.edit-info-save-btn {
  margin-top: 32rpx;
  background: #3B82F6;
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 大纲管理 */
.outline-container {
  padding: 0 8rpx;
}

.outline-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.outline-item {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 16rpx;
  transition: all 0.2s ease;
}

.outline-item.sub-item {
  margin-left: 32rpx;
}

.outline-item.dragging {
  opacity: 0.5;
  background: #E7E7E7;
}

.outline-drag-handle {
  padding: 8rpx;
  margin-right: 8rpx;
}

.outline-main {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.outline-level-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background-color: #e8f4ff;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.outline-level-indicator text {
  font-size: 22rpx;
  color: #3B82F6;
  font-weight: 500;
}

.outline-content {
  flex: 1;
  min-width: 0;
}

.outline-input {
  width: 100%;
  font-size: 28rpx;
  color: #1E293B;
}

.outline-actions {
  flex-shrink: 0;
  margin-left: 8rpx;
}

.action-btn {
  padding: 8rpx;
}

.outline-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.outline-empty text {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 16rpx;
}

.outline-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: rgba(59, 130, 246, 0.08);
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.outline-add-btn text {
  font-size: 28rpx;
  color: #3B82F6;
}

.outline-tips {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #FFF7E6;
  border-radius: 8rpx;
}

.outline-tips text {
  font-size: 24rpx;
  color: #FA8C16;
}

/* 卡片管理 */
.cards-manage-container {
  padding: 0 8rpx;
}

.cards-manage-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.toolbar-left {
  display: flex;
  align-items: center;
}

.batch-toggle-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #64748B;
}

.batch-toggle-btn.active {
  color: #3B82F6;
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-all-btn {
  font-size: 26rpx;
  color: #3B82F6;
  padding: 8rpx 16rpx;
}

.move-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #3B82F6;
  padding: 8rpx 16rpx;
  background: rgba(59, 130, 246, 0.08);
  border-radius: 12rpx;
}

.move-btn.disabled {
  color: #CBD5E1;
  background: #F1F5F9;
}

.selected-count-bar {
  background: #E6F7FF;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.selected-count-bar text {
  font-size: 24rpx;
  color: #3B82F6;
}

.cards-manage-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cards-manage-item {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  border: 2rpx solid transparent;
}

.cards-manage-item.selected {
  background: #E6F7FF;
  border-color: #3B82F6;
}

.cards-manage-info {
  flex: 1;
  min-width: 0;
}

.cards-manage-title {
  font-size: 28rpx;
  color: #1E293B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cards-manage-chapter {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.cards-manage-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.cards-manage-btn {
  padding: 8rpx;
}

.cards-manage-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.cards-manage-empty text {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 16rpx;
}

.cards-manage-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: rgba(59, 130, 246, 0.08);
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.cards-manage-add-btn text {
  font-size: 28rpx;
  color: #3B82F6;
}

/* 章节选择弹窗 */
.chapter-picker-popup {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}

.chapter-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E7E7E7;
}

.chapter-picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.chapter-picker-close {
  padding: 8rpx;
}

.chapter-picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 0;
}

.chapter-picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
}

.chapter-picker-item.selected {
  background: #E6F7FF;
}

.chapter-picker-name {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1E293B;
}

.chapter-level-indicator {
  background: #3B82F6;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.chapter-level-indicator text {
  font-size: 20rpx;
  color: #fff;
}

.chapter-picker-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #E7E7E7;
}

.chapter-picker-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.chapter-picker-btn.cancel {
  background: #F1F5F9;
  color: #64748B;
}

.chapter-picker-btn.confirm {
  background: #3B82F6;
  color: #fff;
}

/* 删除确认弹窗 */
.delete-confirm-popup {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx 32rpx;
  width: 560rpx;
}

.delete-confirm-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
  text-align: center;
  margin-bottom: 24rpx;
}

.delete-confirm-content {
  font-size: 28rpx;
  color: #64748B;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.delete-confirm-actions {
  display: flex;
  gap: 20rpx;
}

.delete-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.delete-btn.cancel {
  background: #F1F5F9;
  color: #64748B;
}

.delete-btn.confirm {
  background: #E34D59;
  color: #fff;
}

/* 批量导入弹窗 */
.batch-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.batch-container {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E7E7E7;
  flex-shrink: 0;
}

.batch-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.batch-close {
  padding: 8rpx;
}

.batch-step {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

.batch-step-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.batch-step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #3B82F6;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.batch-step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.batch-library-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.batch-library-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
}

.batch-library-item.selected {
  background: #E6F7FF;
  border-color: #3B82F6;
}

.batch-library-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #CBD5E1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.batch-library-item.selected .batch-library-radio {
  border-color: #3B82F6;
}

.batch-radio-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #3B82F6;
}

.batch-library-info {
  flex: 1;
}

.batch-library-name {
  font-size: 28rpx;
  color: #1E293B;
  display: block;
  margin-bottom: 4rpx;
}

.batch-library-count {
  font-size: 24rpx;
  color: #64748B;
}

.batch-empty {
  text-align: center;
  padding: 48rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}

.batch-step-footer {
  padding: 24rpx 0;
}

.batch-step-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
}

.batch-prev-btn,
.batch-next-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.batch-prev-btn {
  background: #F1F5F9;
  color: #64748B;
}

.batch-next-btn {
  background: #3B82F6;
  color: #fff;
}

.batch-next-btn.disabled {
  background: #CBD5E1;
}

.batch-upload-area {
  border: 2rpx dashed #CBD5E1;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.batch-upload-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.batch-upload-text {
  font-size: 28rpx;
  color: #1E293B;
  margin-top: 16rpx;
}

.batch-upload-hint {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.batch-upload-done {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.batch-file-name {
  font-size: 28rpx;
  color: #1E293B;
  margin-top: 12rpx;
}

.batch-file-change {
  font-size: 24rpx;
  color: #3B82F6;
  margin-top: 8rpx;
}

.batch-template-section {
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 20rpx;
}

.batch-template-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 16rpx;
}

.batch-template-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.batch-template-row {
  display: flex;
  font-size: 24rpx;
}

.col-a {
  width: 140rpx;
  color: #94A3B8;
}

.col-b {
  color: #1E293B;
}

.batch-download-template {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 8rpx;
}

.batch-download-template text {
  font-size: 26rpx;
  color: #3B82F6;
}

.batch-preview-summary {
  text-align: center;
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.batch-preview-total {
  font-size: 28rpx;
  color: #64748B;
}

.batch-preview-total .highlight {
  color: #3B82F6;
  font-weight: 600;
}

.batch-preview-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.batch-preview-item {
  display: flex;
  padding: 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.batch-preview-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  background: #3B82F6;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.batch-preview-content {
  flex: 1;
  min-width: 0;
}

.batch-preview-q {
  font-size: 26rpx;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.batch-preview-a {
  font-size: 24rpx;
  color: #64748B;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.batch-preview-chapter {
  font-size: 22rpx;
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-top: 8rpx;
}

.batch-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
}

.batch-result-icon {
  margin-bottom: 24rpx;
}

.batch-result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 12rpx;
}

.batch-result-desc {
  font-size: 28rpx;
  color: #64748B;
}
