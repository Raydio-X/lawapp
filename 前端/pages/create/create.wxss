/* 全局容器 */
.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding: 32rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 页面标题 */
.page-header {
  margin-bottom: 48rpx;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 创建入口卡片 */
.create-section {
  margin-bottom: 48rpx;
}

.create-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.create-card.pressed {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.create-card-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.library-icon {
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.3);
}

.card-icon {
  background: linear-gradient(135deg, #00B578 0%, #33C493 100%);
  box-shadow: 0 8rpx 24rpx rgba(0, 181, 120, 0.3);
}

.create-card-content {
  flex: 1;
}

.create-card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.create-card-desc {
  font-size: 26rpx;
  color: #999;
}

.create-card-arrow {
  margin-left: 16rpx;
}

/* 快捷操作 */
.quick-actions {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.quick-action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.quick-action-grid {
  display: flex;
  justify-content: space-around;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  position: relative;
}

.quick-action-item.disabled {
  opacity: 0.5;
}

.quick-action-icon {
  width: 96rpx;
  height: 96rpx;
  background-color: #f5f6fa;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.quick-action-icon.smart-icon {
  background-color: #f0f5ff;
}

.quick-action-icon.batch-icon {
  background-color: #e8f8f0;
}

.quick-action-item:active .quick-action-icon {
  transform: scale(0.95);
}

.quick-action-item:active:not(.disabled) .quick-action-icon {
  background-color: rgba(0, 82, 217, 0.1);
}

.quick-action-text {
  font-size: 26rpx;
  color: #666;
}

.coming-soon-tag {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  font-size: 18rpx;
  color: #fff;
  background: #E37324;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

/* 我的知识库 */
.my-libraries-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.manage-btn {
  font-size: 28rpx;
  color: #0052D9;
  padding: 8rpx 16rpx;
}

.manage-btn:active {
  opacity: 0.7;
}

/* 知识库列表 */
.library-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.library-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.library-item.pressed {
  transform: scale(0.98);
  background-color: #f0f1f2;
}

.library-item:active {
  background-color: #f0f1f2;
}

.library-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background-color: rgba(0, 82, 217, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.library-item-content {
  flex: 1;
  min-width: 0;
}

.library-item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.library-item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #999;
}

.meta-dot {
  font-size: 26rpx;
  color: #ccc;
}

.library-item-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.library-item-delete {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 12rpx 24rpx;
  background-color: #e34d59;
  border-radius: 8rpx;
}

.delete-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.manage-btn.active {
  color: #e34d59;
}

.library-item.manage-mode {
  background-color: #fff;
}

.library-item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-text {
  font-size: 26rpx;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
}

.action-text.edit {
  color: #0052D9;
  background-color: rgba(0, 82, 217, 0.1);
}

.action-text.delete {
  color: #e34d59;
  background-color: rgba(227, 77, 89, 0.1);
}

/* 编辑弹窗 */
.edit-popup {
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.edit-disable-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background-color: transparent;
}

.edit-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.edit-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.edit-popup-done {
  padding: 12rpx 24rpx;
  background-color: #0052D9;
  border-radius: 8rpx;
}

.edit-popup-done text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* Tab 切换 */
.edit-tabs {
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
}

.edit-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.edit-tab.active {
  color: #0052D9;
  font-weight: 600;
}

.edit-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #0052D9;
  border-radius: 2rpx;
}

/* 编辑内容区域 */
.edit-content {
  flex: 1;
  overflow-y: auto;
}

/* 基本信息编辑 */
.edit-info-section {
  padding: 24rpx 32rpx;
}

.edit-info-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.edit-info-label {
  font-size: 28rpx;
  color: #333;
  width: 180rpx;
  flex-shrink: 0;
}

.edit-info-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.edit-info-value {
  font-size: 28rpx;
  color: #999;
}

.edit-info-save-btn {
  margin: 32rpx;
  padding: 24rpx;
  background-color: #0052D9;
  border-radius: 12rpx;
  text-align: center;
}

.edit-info-save-btn text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

/* 卡片管理 */
.cards-manage-container {
  padding: 24rpx 32rpx;
}

.cards-manage-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cards-manage-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.cards-manage-info {
  flex: 1;
  min-width: 0;
}

.cards-manage-title {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cards-manage-chapter {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.cards-manage-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 16rpx;
}

.cards-manage-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
}

.cards-manage-btn:active {
  opacity: 0.7;
}

.cards-manage-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  color: #999;
  font-size: 28rpx;
}

.cards-manage-empty text {
  margin-top: 16rpx;
}

.cards-manage-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  color: #0052D9;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.cards-manage-add-btn:active {
  background-color: rgba(0, 82, 217, 0.04);
  border-color: #0052D9;
}

/* 批量操作工具栏 */
.cards-manage-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.toolbar-left {
  display: flex;
  align-items: center;
}

.batch-toggle-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.batch-toggle-btn.active {
  background-color: #e8f3ff;
  color: #0052D9;
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-all-btn {
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.move-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background-color: #e8f3ff;
  font-size: 26rpx;
  color: #0052D9;
}

.move-btn.disabled {
  background-color: #f5f5f5;
  color: #ccc;
}

.selected-count-bar {
  background-color: #e8f3ff;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #0052D9;
  text-align: center;
}

.cards-manage-item.selected {
  background-color: #e8f3ff !important;
  border: 2rpx solid #0052D9 !important;
}

.cards-manage-item.selected .cards-manage-title {
  color: #0052D9 !important;
}

/* 章节选择弹窗 */
.chapter-picker-popup {
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.chapter-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
}

.chapter-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.chapter-picker-close {
  padding: 8rpx;
}

.chapter-picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 0;
}

.chapter-picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #333;
}

.chapter-picker-item.selected {
  background-color: #e8f3ff;
  color: #0052D9;
}

.chapter-picker-name {
  flex: 1;
  display: flex;
  align-items: center;
}

.chapter-level-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background-color: #e8f4ff;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.chapter-level-indicator text {
  font-size: 22rpx;
  color: #0052D9;
  font-weight: 500;
}

.chapter-picker-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
}

.chapter-picker-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.chapter-picker-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.chapter-picker-btn.confirm {
  background-color: #0052D9;
  color: #fff;
}

.outline-container {
  background-color: #f8f9fa;
  border-radius: 16rpx;
  margin: 24rpx 32rpx;
  padding: 24rpx;
}

.outline-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.outline-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid transparent;
}

.outline-item.sub-item {
  background-color: #fafbfc;
}

.outline-item.dragging {
  opacity: 0.8;
  border-color: #0052D9;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.2);
  transform: scale(1.02);
}

.outline-drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin-right: 12rpx;
  cursor: move;
}

.outline-main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  margin-left: 0;
}

.outline-main.outline-level-2 {
  margin-left: 40rpx;
}

.outline-main.outline-level-3 {
  margin-left: 80rpx;
}

.outline-level-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background-color: #e8f4ff;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.outline-level-indicator text {
  font-size: 22rpx;
  color: #0052D9;
  font-weight: 500;
}

.outline-content {
  flex: 1;
  min-width: 0;
}

.outline-input {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}

.outline-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 12rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #f5f6fa;
  transition: all 0.2s ease;
}

.action-btn:active {
  background-color: #e8e9eb;
}

.outline-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  color: #999;
  font-size: 28rpx;
}

.outline-empty text {
  margin-top: 16rpx;
}

.outline-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  color: #0052D9;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.outline-add-btn:active {
  background-color: rgba(0, 82, 217, 0.04);
  border-color: #0052D9;
}

.outline-tips {
  padding: 16rpx 32rpx 32rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 删除确认弹窗 */
.delete-confirm-popup {
  width: 560rpx;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.delete-confirm-title {
  padding: 40rpx 32rpx 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
}

.delete-confirm-content {
  padding: 8rpx 40rpx 40rpx;
}

.delete-confirm-content text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
  display: block;
}

.delete-confirm-actions {
  display: flex;
  border-top: 2rpx solid #f0f0f0;
}

.delete-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.delete-btn.cancel {
  color: #666;
  border-right: 2rpx solid #f0f0f0;
}

.delete-btn.confirm {
  color: #e34d59;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  gap: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 底部占位 */
.bottom-placeholder {
  height: 48rpx;
}

/* 批量导入弹窗 */
.batch-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.batch-container {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.batch-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.batch-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.batch-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  overflow: hidden;
}

.batch-step-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.batch-step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #0052D9;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.batch-step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.batch-library-list {
  flex: 1;
  overflow-y: auto;
  max-height: 400rpx;
}

.batch-library-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.batch-library-item.selected {
  border-color: #0052D9;
  background: #f0f5ff;
}

.batch-library-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.batch-library-item.selected .batch-library-radio {
  border-color: #0052D9;
}

.batch-radio-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #0052D9;
}

.batch-library-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.batch-library-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.batch-library-count {
  font-size: 24rpx;
  color: #999;
}

.batch-empty {
  text-align: center;
  padding: 48rpx;
  color: #999;
  font-size: 28rpx;
}

.batch-upload-area {
  border: 2rpx dashed #ddd;
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  transition: all 0.2s;
}

.batch-upload-area:active {
  border-color: #00A870;
  background: #f8fdfb;
}

.batch-upload-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.batch-upload-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.batch-upload-hint {
  font-size: 24rpx;
  color: #999;
}

.batch-upload-done {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.batch-file-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.batch-file-change {
  font-size: 24rpx;
  color: #00A870;
}

.batch-template-section {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.batch-template-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.batch-template-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.batch-template-row {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.batch-template-row .col-a {
  width: 160rpx;
  color: #999;
}

.batch-template-row .col-b {
  color: #333;
  font-weight: 500;
}

.batch-download-template {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #0052D9;
  border-radius: 12rpx;
  color: #0052D9;
  font-size: 26rpx;
}

.batch-download-template:active {
  background: #f0f5ff;
}

.batch-step-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: auto;
  padding-top: 24rpx;
}

.batch-step-footer {
  display: flex;
  justify-content: center;
  margin-top: auto;
  padding-top: 24rpx;
}

.batch-prev-btn {
  flex: 0.5;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: #f5f5f5;
  color: #666;
}

.batch-prev-btn:active {
  background: #e8e8e8;
}

.batch-next-btn {
  flex: 0.5;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: #0052D9;
  color: #fff;
}

.batch-next-btn.disabled {
  background: #ccc;
  color: #fff;
}

.batch-preview-summary {
  margin-bottom: 24rpx;
}

.batch-preview-total {
  font-size: 28rpx;
  color: #666;
}

.batch-preview-total .highlight {
  color: #0052D9;
  font-weight: 600;
  font-size: 32rpx;
}

.batch-preview-list {
  flex: 1;
  max-height: 400rpx;
}

.batch-preview-item {
  display: flex;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.batch-preview-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8f4ff;
  color: #0052D9;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.batch-preview-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.batch-preview-q {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.batch-preview-a {
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.batch-preview-chapter {
  font-size: 22rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

.batch-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0;
  gap: 24rpx;
}

.batch-result-icon {
  margin-bottom: 16rpx;
}

.batch-result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.batch-result-desc {
  font-size: 28rpx;
  color: #666;
}
