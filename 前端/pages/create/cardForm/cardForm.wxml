<view class="container">
  <view class="header-decoration"></view>
  
  <view class="form-card">
    <view class="card-header">
      <view class="header-icon">
        <t-icon name="edit-1" size="40rpx" color="#fff" />
      </view>
      <view class="header-text">
        <text class="header-title">{{isEdit ? '编辑卡片' : '创建新卡片'}}</text>
        <text class="header-subtitle">记录知识点，构建你的法律知识体系</text>
      </view>
    </view>

    <view class="form-body">
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">所属知识库</text>
          <text class="label-required">*</text>
        </view>
        <view class="picker-card" bindtap="onSelectLibrary">
          <text class="picker-value {{selectedLibrary ? 'active' : ''}}">{{selectedLibrary ? selectedLibrary.name : '选择知识库'}}</text>
          <t-icon name="chevron-right" size="32rpx" color="#c0c4cc" />
        </view>
      </view>

      <view class="form-item" wx:if="{{selectedLibrary}}">
        <view class="form-label">
          <text class="label-text">所属章节</text>
        </view>
        <view class="picker-card" bindtap="onSelectChapter">
          <text class="picker-value {{selectedChapter ? 'active' : ''}}">{{selectedChapter ? selectedChapter.name : '选择章节（可选）'}}</text>
          <t-icon name="chevron-right" size="32rpx" color="#c0c4cc" />
        </view>
      </view>

      <view class="divider"></view>

      <view class="form-item">
        <view class="form-label">
          <text class="label-text">题目</text>
          <text class="label-required">*</text>
        </view>
        <view class="textarea-card question-card">
          <textarea
            class="form-textarea"
            placeholder="输入法律问题或考点..."
            placeholder-class="placeholder"
            bindinput="onQuestionInput"
            value="{{question}}"
            maxlength="100"
            auto-height
          />
          <view class="textarea-footer">
            <text class="hint-text">简洁明了，突出核心考点</text>
            <text class="char-count">{{question.length}}/100</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text class="label-text">答案</text>
          <text class="label-required">*</text>
        </view>
        <view class="textarea-card answer-card">
          <textarea
            class="form-textarea answer-textarea"
            placeholder="输入答案解析，支持分点作答..."
            placeholder-class="placeholder"
            bindinput="onAnswerInput"
            value="{{answer}}"
            maxlength="500"
            auto-height
          />
          <view class="textarea-footer">
            <text class="hint-text">详细解析，加深理解记忆</text>
            <text class="char-count">{{answer.length}}/500</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="btn-cancel" bindtap="onCancel">取消</view>
    <view class="btn-submit {{canSubmit ? '' : 'disabled'}}" bindtap="onSubmit">
      <t-icon name="check" size="32rpx" color="#fff" />
      <text>{{isEdit ? '保存修改' : '创建卡片'}}</text>
    </view>
  </view>

  <t-picker
    visible="{{showLibraryPicker}}"
    value="{{selectedLibraryIndex}}"
    data-key="library"
    title="选择知识库"
    confirm-btn="确定"
    cancel-btn="取消"
    bindpick="onLibraryPick"
    bindconfirm="onLibraryConfirm"
    bindcancel="onPickerCancel"
  >
    <t-picker-item options="{{libraryOptions}}"></t-picker-item>
  </t-picker>

  <t-picker
    visible="{{showChapterPicker}}"
    value="{{selectedChapterIndex}}"
    data-key="chapter"
    title="选择章节"
    confirm-btn="确定"
    cancel-btn="取消"
    bindpick="onChapterPick"
    bindconfirm="onChapterConfirm"
    bindcancel="onPickerCancel"
  >
    <t-picker-item options="{{chapterOptions}}"></t-picker-item>
  </t-picker>
</view>
