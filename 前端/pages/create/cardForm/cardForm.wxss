.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4f8 0%, #f8fafc 100%);
  padding: 32rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

.header-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 50%, #93C5FD 100%);
  border-radius: 0 0 60rpx 60rpx;
  z-index: 0;
}

.form-card {
  position: relative;
  z-index: 1;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(59, 130, 246, 0.12);
}

.card-header {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  margin: 24rpx;
  border-radius: 16rpx;
}

.header-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.header-text {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
}

.form-body {
  padding: 16rpx 32rpx 32rpx;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
}

.label-required {
  font-size: 28rpx;
  color: #e74c3c;
  margin-left: 8rpx;
}

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #e8ecf0, transparent);
  margin: 32rpx 0;
}

.picker-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e8ecf0;
  transition: all 0.3s ease;
}

.picker-card:active {
  background: #f0f4f8;
  border-color: #3B82F6;
}

.picker-value {
  font-size: 30rpx;
  color: #95a5a6;
}

.picker-value.active {
  color: #2c3e50;
  font-weight: 500;
}

.textarea-card {
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e8ecf0;
  padding: 24rpx;
  transition: all 0.3s ease;
}

.textarea-card:focus-within {
  border-top-color: #3B82F6;
  border-right-color: #3B82F6;
  border-bottom-color: #3B82F6;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.08);
}

.answer-card:focus-within {
  border-top-color: #10B981;
  border-right-color: #10B981;
  border-bottom-color: #10B981;
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.08);
}

.question-card {
  border-left: 6rpx solid #3B82F6;
}

.answer-card {
  border-left: 6rpx solid #10B981;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: #2c3e50;
}

.answer-textarea {
  min-height: 200rpx;
}

.placeholder {
  font-size: 30rpx;
  color: #bdc3c7;
}

.textarea-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e8ecf0;
}

.hint-text {
  font-size: 24rpx;
  color: #95a5a6;
}

.char-count {
  font-size: 24rpx;
  color: #95a5a6;
  font-weight: 500;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(59, 130, 246, 0.08);
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #7f8c8d;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e8ecf0;
}

.btn-cancel:active {
  background: #e8ecf0;
}

.btn-submit {
  flex: 2;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.btn-submit:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-submit.disabled {
  background: linear-gradient(135deg, #bdc3c7 0%, #95a5a6 100%);
  box-shadow: none;
}
