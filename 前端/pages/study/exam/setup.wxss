.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx 28rpx 200rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.section-value {
  font-size: 28rpx;
  color: #0052D9;
  font-weight: 600;
}

.tabs {
  display: flex;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #fff;
  color: #0052D9;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.library-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.library-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  transition: all 0.3s;
}

.library-item.selected {
  background: #e8f0ff;
  border-color: #0052D9;
}

.library-item:last-child {
  margin-bottom: 0;
}

.library-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.library-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.library-item.selected .library-name {
  color: #0052D9;
  font-weight: 600;
}

.library-count {
  font-size: 24rpx;
  color: #999;
}

.library-item.selected .library-count {
  color: #0052D9;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.count-options {
  display: flex;
  gap: 16rpx;
}

.count-option {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.count-option.active {
  background: #f0f5ff;
  color: #0052D9;
  border-color: #0052D9;
  font-weight: 600;
}

.duration-slider {
  padding: 10rpx 0;
}

.duration-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.duration-labels text {
  font-size: 22rpx;
  color: #999;
}

.mode-options {
  display: flex;
  gap: 16rpx;
}

.mode-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.mode-option.active {
  background: #f0f5ff;
  border-color: #0052D9;
}

.mode-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-top: 12rpx;
}

.mode-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.summary-card {
  background: linear-gradient(135deg, #0052D9 0%, #3366FF 100%);
  border-radius: 16rpx;
  padding: 28rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.summary-row:not(:last-child) {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.15);
}

.summary-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.summary-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.start-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #0052D9 0%, #3366FF 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.start-btn.disabled {
  background: #ccc;
}
