.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 140rpx;
  padding-top: calc(var(--status-bar-height, 20px) + 44px);
}

.custom-nav {
  background: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.question-list {
  padding: 20rpx 28rpx;
}

.question-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.question-number {
  font-size: 26rpx;
  color: #666;
  background: #f5f7fa;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.question-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.answer-section {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.answer-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.answer-row:last-child {
  margin-bottom: 0;
}

.answer-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.answer-text {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.answer-text.user-answer {
  color: #3B82F6;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
