.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7ff 0%, #ffffff 30%);
  padding: 0 28rpx 140rpx;
}

/* 问候语区域 */
.greeting-section {
  padding: 40rpx 0 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.greeting-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.greeting-text {
  font-size: 42rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.greeting-sub {
  font-size: 24rpx;
  color: #999;
}

.streak-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEDD0 100%);
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
}

.streak-badge text {
  font-size: 24rpx;
  font-weight: 600;
  color: #FF9500;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #f0f0f0;
}

/* 主要学习入口 */
.main-actions {
  margin-bottom: 24rpx;
}

.action-card.primary {
  background: linear-gradient(135deg, #0052D9 0%, #3366FF 100%);
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(0, 82, 217, 0.25);
}

.action-bg {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.action-content {
  position: relative;
  z-index: 1;
}

.action-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.action-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-badge {
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.action-badge text {
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
}

.action-card.primary .action-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.action-card.primary .action-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 小卡片行 */
.action-row {
  display: flex;
  gap: 16rpx;
}

.action-card.small {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-card.small .action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-card.small.smart .action-icon-wrap {
  background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%);
}

.action-card.small.review .action-icon-wrap {
  background: linear-gradient(135deg, #fff3e8 0%, #ffe8d0 100%);
}

.action-card.small .action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.action-card.small .action-desc {
  font-size: 22rpx;
  color: #999;
}

/* 功能模块 */
.module-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.module-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.module-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.exam-icon {
  background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%);
}

.wrong-icon {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
}

.fav-icon {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}

.diff-icon {
  background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
}

.module-info {
  flex: 1;
  min-width: 0;
}

.module-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.module-desc {
  font-size: 24rpx;
  color: #999;
}

/* 提示区域 */
.tips-section {
  margin-top: 32rpx;
}

.tips-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #f0fdf4;
  border-radius: 14rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #00B578;
  font-weight: 500;
}
