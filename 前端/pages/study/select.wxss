.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 140rpx;
}

/* 提示栏 */
.tips-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx;
  background: #e8f0ff;
}

.tips-text {
  font-size: 26rpx;
  color: #0052D9;
}

/* 知识库列表 */
.library-list {
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.library-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.library-item.selected {
  border-color: #0052D9;
  background: #f8faff;
}

.library-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
  transition: all 0.2s;
}

.library-item.selected .library-checkbox {
  border-color: #0052D9;
  background: #0052D9;
}

.checkbox-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.library-info {
  flex: 1;
  min-width: 0;
}

.library-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.library-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.library-badge {
  background: #fff0f0;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  line-height: 1;
}

.library-badge text {
  font-size: 20rpx;
  color: #E34D59;
  line-height: 1;
}

.source-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  line-height: 1;
}

.source-tag text {
  font-size: 20rpx;
  line-height: 1;
}

.source-tag.my {
  background: #e8f0ff;
}

.source-tag.my text {
  color: #0052D9;
}

.source-tag.favorite {
  background: #fff7e6;
}

.source-tag.favorite text {
  color: #FF9500;
}

.library-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.meta-divider {
  color: #ddd;
}

.progress-bar {
  width: 100%;
}

.progress-track {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0052D9 0%, #3366FF 100%);
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-top: 24rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
  margin-top: 12rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all .checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.select-all .checkbox-inner.checked {
  border-color: #0052D9;
  background: #0052D9;
}

.select-all text {
  font-size: 28rpx;
  color: #666;
}

.action-buttons {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.random-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 22rpx 32rpx;
  border-radius: 40rpx;
  background: #f5f6fa;
  border: 2rpx solid #e8e8e8;
  transition: all 0.2s;
}

.random-btn.active {
  background: linear-gradient(135deg, #FAAD14 0%, #FFB800 100%);
  border-color: transparent;
  box-shadow: 0 6rpx 20rpx rgba(250, 173, 20, 0.3);
}

.random-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #999;
}

.random-btn.active text {
  color: #fff;
}

.start-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 22rpx 48rpx;
  border-radius: 40rpx;
  background: #ccc;
  transition: all 0.2s;
}

.start-btn.active {
  background: linear-gradient(135deg, #0052D9 0%, #3366FF 100%);
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.3);
}

.start-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.selected-count {
  font-size: 24rpx !important;
  font-weight: 400 !important;
  opacity: 0.9;
}

/* 底部占位 */
.bottom-placeholder {
  height: 40rpx;
}
