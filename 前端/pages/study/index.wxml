<view class="container">
  <!-- 顶部问候语 -->
  <view class="greeting-section">
    <view class="greeting-left">
      <text class="greeting-text">{{greeting}}</text>
      <text class="greeting-sub">今天也要加油学习哦~</text>
    </view>
    <view class="streak-badge" wx:if="{{streak > 0}}">
      <t-icon name="fire" size="28rpx" color="#FF9500" />
      <text>{{streak}}天</text>
    </view>
  </view>

  <!-- 主要学习入口 -->
  <view class="main-actions">
    <view class="action-card primary" bindtap="onStartStudy">
      <view class="action-decor">
        <t-icon name="book" size="120rpx" color="rgba(255, 255, 255, 0.15)" />
      </view>
      <view class="action-content">
        <view class="action-main">
          <view class="action-text-wrap">
            <text class="action-title">开始学习</text>
            <text class="action-desc">学习未掌握的卡片</text>
          </view>
          <view class="action-icon-wrap">
            <t-icon name="play-circle" size="48rpx" color="#fff" />
          </view>
        </view>
        <view class="action-badge" wx:if="{{unlearnedCount > 0}}">
          <text>{{unlearnedCount}}张待学</text>
        </view>
      </view>
    </view>

    <view class="action-row">
      <view class="action-card small smart" bindtap="onSmartExam">
        <view class="action-icon-wrap">
          <t-icon name="file-add" size="40rpx" color="#7C3AED" />
        </view>
        <text class="action-title">模拟组卷</text>
        <text class="action-desc">自定义模拟考试</text>
      </view>

      <view class="action-card small review" bindtap="onReview">
        <view class="action-icon-wrap">
          <t-icon name="history" size="40rpx" color="#FF9500" />
        </view>
        <text class="action-title">复习回顾</text>
        <text class="action-desc">{{reviewCount}}张待复习</text>
      </view>
    </view>
  </view>

  <!-- 功能模块 -->
  <view class="module-section">
    <view class="module-card" bindtap="onFavorites">
      <view class="module-icon fav-icon">
        <t-icon name="star" size="44rpx" color="#FFB800" />
      </view>
      <view class="module-info">
        <text class="module-title">我的收藏</text>
        <text class="module-desc">{{favoriteCount}}张收藏卡片</text>
      </view>
      <t-icon name="chevron-right" size="36rpx" color="#ccc" />
    </view>

    <view class="module-card" bindtap="onDifficulty">
      <view class="module-icon diff-icon">
        <t-icon name="chart" size="44rpx" color="#3B82F6" />
      </view>
      <view class="module-info">
        <text class="module-title">难度挑战</text>
        <text class="module-desc">挑战高难度卡片</text>
      </view>
      <t-icon name="chevron-right" size="36rpx" color="#ccc" />
    </view>
  </view>

  <!-- 学习提示 -->
  <view class="tips-section" wx:if="{{unlearnedCount === 0}}">
    <view class="tips-card">
      <t-icon name="check-circle" size="40rpx" color="#00B578" />
      <text class="tips-text">太棒了！所有卡片都已掌握</text>
    </view>
  </view>
</view>
