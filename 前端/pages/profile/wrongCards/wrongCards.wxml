<view class="container">
  <view class="header">
    <view class="stats">
      <view class="stat-item">
        <text class="stat-value">{{stats.total}}</text>
        <text class="stat-label">总错题</text>
      </view>
      <view class="stat-item">
        <text class="stat-value mastered">{{stats.mastered}}</text>
        <text class="stat-label">已掌握</text>
      </view>
      <view class="stat-item">
        <text class="stat-value unmastered">{{stats.unmastered}}</text>
        <text class="stat-label">未掌握</text>
      </view>
    </view>
  </view>

  <view class="list" wx:if="{{!loading && wrongCards.length > 0}}">
    <view 
      class="item {{item.pressed ? 'pressed' : ''}} {{item.isMastered ? 'mastered' : ''}}" 
      wx:for="{{wrongCards}}" 
      wx:key="id"
      bindtap="onItemTap"
      bindtouchstart="onItemTouchStart"
      bindtouchend="onItemTouchEnd"
      data-index="{{index}}"
    >
      <view class="item-content">
        <view class="item-status {{item.isMastered ? 'mastered' : ''}}">
          <t-icon name="{{item.isMastered ? 'check-circle-filled' : 'error-circle'}}" size="40rpx" color="{{item.isMastered ? '#00B578' : '#E34D59'}}" />
        </view>
        <view class="item-info">
          <text class="item-question">{{item.question}}</text>
          <view class="item-meta">
            <text class="item-library">{{item.libraryName}}</text>
            <text class="item-time">{{item.time}}</text>
          </view>
        </view>
      </view>
      <view class="item-actions">
        <view class="action-btn" catchtap="onToggleMastered" data-index="{{index}}">
          <t-icon name="{{item.isMastered ? 'rollback' : 'check'}}" size="36rpx" color="{{item.isMastered ? '#999' : '#00B578'}}" />
        </view>
        <view class="action-btn" catchtap="onRemove" data-index="{{index}}">
          <t-icon name="close" size="36rpx" color="#999" />
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && wrongCards.length === 0}}">
    <t-icon name="check-circle" size="96rpx" color="#00B578" />
    <text>太棒了！暂无错题</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <t-loading theme="circular" size="40rpx" />
    <text>加载中...</text>
  </view>
</view>
