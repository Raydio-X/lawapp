.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: env(safe-area-inset-bottom);
}

.header {
  background-color: #fff;
  padding: 32rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-value.mastered {
  color: #00B578;
}

.stat-value.unmastered {
  color: #E34D59;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.list {
  padding: 24rpx;
}

.item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
  border-left: 6rpx solid #E34D59;
}

.item.mastered {
  border-left-color: #00B578;
  opacity: 0.8;
}

.item.pressed {
  background-color: #f5f6fa;
  transform: scale(0.98);
}

.item-content {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.item-status {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.item-info {
  flex: 1;
  overflow: hidden;
}

.item-question {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  gap: 16rpx;
}

.item-library {
  font-size: 24rpx;
  color: #0052D9;
}

.item-time {
  font-size: 24rpx;
  color: #999;
}

.item-actions {
  display: flex;
  gap: 8rpx;
}

.action-btn {
  padding: 16rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
}

.empty text {
  margin-top: 24rpx;
  font-size: 28rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
}

.loading text {
  margin-top: 24rpx;
  font-size: 28rpx;
}
