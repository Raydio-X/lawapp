<view class="container">
  <!-- 用户信息区 -->
  <view class="user-section">
    <view class="user-card">
      <view class="user-info">
        <t-avatar 
          class="user-avatar"
          image="{{userInfo.avatarUrl}}" 
          size="large"
          shape="circle"
        />
        <view class="user-detail">
          <text class="user-name">{{userInfo.nickName || '法硕考生'}}</text>
        </view>
      </view>
      <view class="user-edit" bindtap="onEditProfile">
        <t-icon name="edit" size="32rpx" color="#999" />
      </view>
    </view>

    <!-- 数据统计 -->
    <view class="stats-section">
      <view class="stat-item" bindtap="onStatTap" data-type="library">
        <text class="stat-number">{{stats.libraryCount}}</text>
        <text class="stat-label">知识库</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onStatTap" data-type="card">
        <text class="stat-number">{{stats.cardCount}}</text>
        <text class="stat-label">卡片</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onStatTap" data-type="favorite">
        <text class="stat-number">{{stats.favoriteCount}}</text>
        <text class="stat-label">收藏</text>
      </view>
    </view>
  </view>

  <!-- 今日学习 -->
  <view class="today-section">
    <view class="section-header">
      <text class="section-title">今日学习</text>
      <text class="section-more" bindtap="onViewDetail">查看详情</text>
    </view>
    
    <!-- 核心数据卡片 -->
    <view class="core-stats">
      <view class="core-stat-item">
        <view class="core-stat-icon time-icon">
          <t-icon name="time" size="40rpx" color="#3B82F6" />
        </view>
        <view class="core-stat-content">
          <text class="core-stat-value">{{studyProgress.totalTime}}</text>
          <text class="core-stat-label">学习时长</text>
        </view>
      </view>
      <view class="core-stat-divider"></view>
      <view class="core-stat-item">
        <view class="core-stat-icon streak-icon">
          <t-icon name="calendar" size="40rpx" color="#FF6B35" />
        </view>
        <view class="core-stat-content">
          <text class="core-stat-value">{{studyProgress.streak}}天</text>
          <text class="core-stat-label">连续打卡</text>
        </view>
      </view>
    </view>

    <!-- 今日目标 -->
    <view class="goal-card">
      <view class="goal-header">
        <text class="goal-title">今日目标</text>
        <text class="goal-progress">{{studyProgress.todayCards}}/{{studyProgress.dailyGoal}}张</text>
      </view>
      <view class="goal-bar">
        <view class="goal-bar-fill" style="width: {{goalPercent}}%"></view>
      </view>
      <text class="goal-hint" wx:if="{{studyProgress.todayCards >= studyProgress.dailyGoal}}">🎉 今日目标已达成！</text>
      <text class="goal-hint" wx:else>还差{{studyProgress.dailyGoal - studyProgress.todayCards}}张完成目标</text>
    </view>

    <!-- 学习数据网格 -->
    <view class="stats-grid">
      <view class="grid-item">
        <text class="grid-value">{{studyProgress.todayNew}}</text>
        <text class="grid-label">今日新学</text>
      </view>
      <view class="grid-item">
        <text class="grid-value">{{studyProgress.weekTime}}</text>
        <text class="grid-label">本周累计</text>
        <view class="grid-trend up" wx:if="{{studyProgress.weekTrend > 0}}">↑{{studyProgress.weekTrend}}%</view>
        <view class="grid-trend down" wx:elif="{{studyProgress.weekTrend < 0}}">↓{{-studyProgress.weekTrend}}%</view>
      </view>
      <view class="grid-item">
        <text class="grid-value">{{studyProgress.toReview}}</text>
        <text class="grid-label">待复习</text>
        <view class="grid-tag review" wx:if="{{studyProgress.toReview > 0}}">需复习</view>
      </view>
      <view class="grid-item">
        <text class="grid-value">{{studyProgress.totalCards}}</text>
        <text class="grid-label">累计背诵</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <t-cell-group>
      <t-cell 
        title="我的收藏" 
        hover 
        arrow
        bindtap="onMenuTap"
        data-menu="favorite"
      >
        <t-icon slot="left-icon" name="star" size="44rpx" color="#FFAD1F" />
        <view slot="note" class="custom-badge" wx:if="{{stats.favoriteCount > 0}}">{{stats.favoriteCount}}</view>
      </t-cell>
      <t-cell 
        title="消息中心" 
        hover 
        arrow
        bindtap="onMenuTap"
        data-menu="message"
      >
        <t-icon slot="left-icon" name="notification" size="44rpx" color="#3B82F6" />
        <view slot="note" class="badge-number" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
      </t-cell>
    </t-cell-group>
  </view>

  <!-- 其他功能 -->
  <view class="menu-section">
    <t-cell-group>
      <t-cell 
        title="我的成就" 
        hover 
        arrow
        bindtap="onMenuTap"
        data-menu="achievement"
      >
        <t-icon slot="left-icon" name="certificate" size="44rpx" color="#E37324" />
      </t-cell>
      <t-cell 
        title="学习计划" 
        hover 
        arrow
        bindtap="onMenuTap"
        data-menu="plan"
      >
        <t-icon slot="left-icon" name="calendar" size="44rpx" color="#00A870" />
      </t-cell>
      <t-cell 
        title="激活中心" 
        hover 
        arrow
        bindtap="onMenuTap"
        data-menu="activation"
      >
        <t-icon slot="left-icon" name="link" size="44rpx" color="#7B61FF" />
      </t-cell>
    </t-cell-group>
  </view>

  <!-- 退出登录 -->
  <view class="menu-section logout-section">
    <t-cell-group>
      <t-cell 
        title="退出登录" 
        hover
        bindtap="onLogout"
      >
        <t-icon slot="left-icon" name="logout" size="44rpx" color="#E34D59" />
      </t-cell>
    </t-cell-group>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>法硕背诵助手 v1.0.0</text>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>

  <!-- 学习计划弹窗 -->
  <view class="plan-popup" wx:if="{{showPlanPicker}}" bindtap="onClosePlanPicker">
    <view class="plan-picker-container" catchtap="preventClose">
      <view class="plan-picker-header">
        <text class="plan-picker-title">设置每日学习目标</text>
        <view class="plan-picker-close" bindtap="onClosePlanPicker">
          <t-icon name="close" size="32rpx" color="#999" />
        </view>
      </view>
      
      <view class="plan-picker-body">
        <picker-view 
          class="plan-picker-view" 
          value="{{pickerValue}}" 
          bindchange="onPickerChange"
          indicator-style="height: 88rpx;"
        >
          <picker-view-column>
            <view class="picker-item" wx:for="{{cardCountOptions}}" wx:key="*this">
              {{item}} 张
            </view>
          </picker-view-column>
        </picker-view>
      </view>
      
      <view class="plan-picker-footer">
        <view class="plan-picker-btn confirm" bindtap="onConfirmPlan">确定</view>
      </view>
    </view>
  </view>
</view>
