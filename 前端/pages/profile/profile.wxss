.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.user-section {
  position: relative;
  background: linear-gradient(180deg, #3B82F6 0%, #60A5FA 40%, #FFFFFF 100%);
  padding: 48rpx 32rpx 32rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.4;
  pointer-events: none;
}

.glow-1 {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.6);
  top: -60rpx;
  right: 60rpx;
}

.glow-2 {
  width: 150rpx;
  height: 150rpx;
  background: rgba(59, 130, 246, 0.3);
  bottom: 40rpx;
  left: -30rpx;
}

.glow-3 {
  width: 120rpx;
  height: 120rpx;
  background: rgba(96, 165, 250, 0.4);
  top: 80rpx;
  left: 100rpx;
}

.star {
  position: absolute;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  pointer-events: none;
  animation: twinkle 2s ease-in-out infinite;
}

.star-1 {
  top: 30rpx;
  right: 80rpx;
  animation-delay: 0s;
}

.star-2 {
  top: 100rpx;
  right: 200rpx;
  animation-delay: 0.5s;
  font-size: 20rpx;
}

.star-3 {
  bottom: 80rpx;
  right: 40rpx;
  animation-delay: 1s;
}

.star-4 {
  top: 60rpx;
  left: 60rpx;
  animation-delay: 1.5s;
  font-size: 18rpx;
}

@keyframes twinkle {
  0%, 100% {
    opacity: 0.3;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.user-card {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.user-edit {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.25);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.user-edit:active {
  background-color: rgba(255, 255, 255, 0.4);
}

.stats-section {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 0 24rpx;
}

.stat-item:active {
  opacity: 0.9;
}

.stat-item:not(:last-child) {
  border-right: 2rpx solid #E2E8F0;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
}

.today-section {
  background-color: #fff;
  margin: 24rpx 32rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.section-more {
  font-size: 26rpx;
  color: #3B82F6;
}

.core-stats {
  display: flex;
  background: linear-gradient(135deg, #f8faff 0%, #f0f5ff 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.core-stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.core-stat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-icon {
  background: linear-gradient(135deg, #e8f0ff 0%, #d4e4ff 100%);
}

.streak-icon {
  background: linear-gradient(135deg, #fff3e8 0%, #ffe4d4 100%);
}

.core-stat-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.core-stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
}

.core-stat-label {
  font-size: 24rpx;
  color: #64748B;
}

.core-stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(0, 0, 0, 0.08);
  margin: 0 16rpx;
}

.goal-card {
  background: linear-gradient(135deg, #f0f7ff 0%, #e8f4ff 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.goal-progress {
  font-size: 28rpx;
  font-weight: 600;
  color: #3B82F6;
}

.goal-bar {
  height: 16rpx;
  background-color: rgba(59, 130, 246, 0.15);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.goal-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.goal-hint {
  font-size: 24rpx;
  color: #64748B;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.grid-item {
  background-color: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.grid-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
}

.grid-label {
  font-size: 24rpx;
  color: #64748B;
}

.grid-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.grid-tag.good {
  background-color: #e8f7ed;
  color: #10B981;
}

.grid-tag.normal {
  background-color: #fff7e8;
  color: #F59E0B;
}

.grid-tag.improve {
  background-color: #ffebe8;
  color: #EF4444;
}

.grid-tag.review {
  background-color: #f0e8ff;
  color: #8B5CF6;
}

.grid-trend {
  font-size: 22rpx;
  font-weight: 500;
  margin-top: 4rpx;
}

.grid-trend.up {
  color: #10B981;
}

.grid-trend.down {
  color: #EF4444;
}

.menu-section {
  margin: 24rpx 32rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.menu-section .t-cell {
  align-items: center;
}

.menu-section .t-cell__left-icon {
  display: flex;
  align-items: center;
}

.menu-section .t-cell__title {
  margin-top: -9rpx;
}

.custom-badge {
  font-size: 28rpx;
  font-weight: 500;
  color: #64748B;
  margin-right: 8rpx;
  margin-top: -6rpx;
}

.custom-badge.wrong {
  color: #64748B;
}

.badge-number {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #EF4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.menu-section .t-cell__right {
  display: flex;
  align-items: center;
  flex-direction: row;
}

.logout-section {
  margin-top: 48rpx;
}

.logout-section .t-cell {
  justify-content: center;
}

.logout-section .t-cell__title {
  color: #EF4444;
  text-align: center;
}

.version-info {
  text-align: center;
  padding: 48rpx 0;
  font-size: 24rpx;
  color: #94A3B8;
}

.bottom-placeholder {
  height: 48rpx;
}

.plan-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.plan-picker-container {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.plan-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.plan-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.plan-picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8FAFC;
  border-radius: 50%;
}

.plan-picker-body {
  padding: 24rpx 0;
}

.plan-picker-view {
  height: 400rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #1E293B;
}

.plan-picker-footer {
  display: flex;
  justify-content: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.plan-picker-btn {
  width: 45%;
  height: 75rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.plan-picker-btn.confirm {
  background: #3B82F6;
  color: #fff;
}

.nickname-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}

.nickname-popup-container {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: scaleIn 0.2s ease;
}

@keyframes scaleIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.nickname-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.nickname-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.nickname-popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8FAFC;
  border-radius: 50%;
}

.nickname-popup-body {
  padding: 40rpx 32rpx 60rpx;
}

.nickname-input-wrapper {
  display: flex;
  align-items: center;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  background: #F8FAFC;
}

.nickname-input-wrapper:focus-within {
  border-color: #3B82F6;
  background: #fff;
}

.nickname-input {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: #1E293B;
}

.nickname-count {
  font-size: 26rpx;
  color: #94A3B8;
  margin-left: 16rpx;
}

.nickname-popup-footer {
  display: flex;
  border-top: 1rpx solid #E2E8F0;
}

.nickname-popup-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.nickname-popup-btn.cancel {
  color: #64748B;
  border-right: 1rpx solid #E2E8F0;
}

.nickname-popup-btn.confirm {
  color: #3B82F6;
}
