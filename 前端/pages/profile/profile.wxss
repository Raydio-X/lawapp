/* 全局容器 */
.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 用户信息区 */
.user-section {
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
  padding: 48rpx 32rpx 32rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 24rpx;
}

.user-card {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.user-bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-edit {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-edit:active {
  background-color: rgba(255, 255, 255, 0.3);
}

/* 数据统计 */
.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 32rpx 0;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-item:active {
  opacity: 0.8;
}

.stat-number {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

/* 学习进度 */
.progress-section {
  background-color: #fff;
  margin: 24rpx 32rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.progress-more {
  font-size: 26rpx;
  color: #0052D9;
}

.progress-content {
  display: flex;
  align-items: center;
  gap: 48rpx;
}

.progress-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: conic-gradient(#0052D9 0% 65%, #f0f0f0 65% 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.progress-ring::before {
  content: '';
  width: 130rpx;
  height: 130rpx;
  background-color: #fff;
  border-radius: 50%;
  position: absolute;
}

.progress-info {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-percent {
  font-size: 36rpx;
  font-weight: 700;
  color: #0052D9;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
}

.progress-stats {
  flex: 1;
  display: flex;
  justify-content: space-around;
}

.progress-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.progress-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.progress-label {
  font-size: 24rpx;
  color: #999;
}

/* 菜单区域 */
.menu-section {
  margin: 24rpx 32rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 退出登录区域 */
.logout-section {
  margin-top: 48rpx;
}

.logout-section .t-cell {
  justify-content: center;
}

.logout-section .t-cell__title {
  color: #E34D59;
  text-align: center;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 48rpx 0;
  font-size: 24rpx;
  color: #ccc;
}

/* 底部占位 */
.bottom-placeholder {
  height: 48rpx;
}
