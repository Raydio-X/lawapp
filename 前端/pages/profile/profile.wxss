/* 全局容器 */
.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 用户信息区 */
.user-section {
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
  padding: 48rpx 32rpx 32rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 24rpx;
}

.user-card {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.user-bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-edit {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-edit:active {
  background-color: rgba(255, 255, 255, 0.3);
}

/* 数据统计 */
.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 32rpx 0;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-item:active {
  opacity: 0.8;
}

.stat-number {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

/* 今日学习 */
.today-section {
  background-color: #fff;
  margin: 24rpx 32rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #0052D9;
}

/* 核心数据卡片 */
.core-stats {
  display: flex;
  background: linear-gradient(135deg, #f8faff 0%, #f0f5ff 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.core-stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.core-stat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-icon {
  background: linear-gradient(135deg, #e8f0ff 0%, #d4e4ff 100%);
}

.streak-icon {
  background: linear-gradient(135deg, #fff3e8 0%, #ffe4d4 100%);
}

.core-stat-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.core-stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.core-stat-label {
  font-size: 24rpx;
  color: #999;
}

.core-stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(0, 0, 0, 0.08);
  margin: 0 16rpx;
}

/* 今日目标 */
.goal-card {
  background: linear-gradient(135deg, #f0f7ff 0%, #e8f4ff 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.goal-progress {
  font-size: 28rpx;
  font-weight: 600;
  color: #0052D9;
}

.goal-bar {
  height: 16rpx;
  background-color: rgba(0, 82, 217, 0.15);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.goal-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #0052D9 0%, #336FE3 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.goal-hint {
  font-size: 24rpx;
  color: #666;
}

/* 学习数据网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.grid-item {
  background-color: #f8f9fc;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.grid-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.grid-label {
  font-size: 24rpx;
  color: #999;
}

.grid-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.grid-tag.good {
  background-color: #e8f7ed;
  color: #00a870;
}

.grid-tag.normal {
  background-color: #fff7e8;
  color: #fa8c16;
}

.grid-tag.improve {
  background-color: #ffebe8;
  color: #e34d59;
}

.grid-tag.review {
  background-color: #f0e8ff;
  color: #7b61ff;
}

.grid-trend {
  font-size: 22rpx;
  font-weight: 500;
  margin-top: 4rpx;
}

.grid-trend.up {
  color: #00a870;
}

.grid-trend.down {
  color: #e34d59;
}

/* 菜单区域 */
.menu-section {
  margin: 24rpx 32rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.menu-section .t-cell {
  align-items: center;
}

.menu-section .t-cell__left-icon {
  display: flex;
  align-items: center;
}

.menu-section .t-cell__title {
  margin-top: -9rpx;
}

/* 自定义数字标签 */
.custom-badge {
  font-size: 28rpx;
  font-weight: 500;
  color: #999;
  margin-right: 8rpx;
  margin-top: -6rpx;
}

.custom-badge.wrong {
  color: #999;
}

/* 菜单项右侧内容 */
.menu-section .t-cell__right {
  display: flex;
  align-items: center;
  flex-direction: row;
}

/* 退出登录区域 */
.logout-section {
  margin-top: 48rpx;
}

.logout-section .t-cell {
  justify-content: center;
}

.logout-section .t-cell__title {
  color: #E34D59;
  text-align: center;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 48rpx 0;
  font-size: 24rpx;
  color: #ccc;
}

/* 底部占位 */
.bottom-placeholder {
  height: 48rpx;
}
