.study-container {
  min-height: 100vh;
  background-color: #F5F7FA;
  display: flex;
  flex-direction: column;
  padding-bottom: 140rpx;
}

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #64748B;
  margin-top: 24rpx;
}

.question-section {
  background: #fff;
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  margin-bottom: 24rpx;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-number {
  font-size: 26rpx;
  color: #64748B;
  font-weight: 500;
}

.card-tags {
  display: flex;
  gap: 12rpx;
}

.progress-bar {
  margin-top: 16rpx;
}

.progress-track {
  height: 8rpx;
  background-color: #E2E8F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.question-content {
  padding: 24rpx 0;
}

.question-title {
  font-size: 34rpx;
  color: #1E293B;
  line-height: 1.8;
  font-weight: 500;
}

.answer-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.answer-hidden {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hint-text {
  font-size: 28rpx;
  color: #94A3B8;
  margin-bottom: 32rpx;
}

.reveal-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.reveal-btn:active {
  transform: scale(0.98);
}

.answer-revealed {
  padding: 32rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.answer-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.answer-label text {
  font-size: 28rpx;
  color: #10B981;
  font-weight: 500;
}

.answer-content {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 4rpx solid #10B981;
}

.answer-text {
  font-size: 30rpx;
  color: #1E293B;
  line-height: 1.8;
}

.comment-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: fadeIn 0.3s ease;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #E2E8F0;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.comment-count {
  font-size: 26rpx;
  color: #64748B;
}

.comment-list {
  max-height: 400rpx;
  margin-bottom: 24rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.comment-avatar text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.comment-content {
  flex: 1;
  min-width: 0;
}

.comment-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.username {
  font-size: 26rpx;
  color: #1E293B;
  font-weight: 500;
}

.time {
  font-size: 22rpx;
  color: #94A3B8;
}

.comment-text {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.6;
  display: block;
}

.comment-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 12rpx;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #64748B;
}

.like-btn.liked {
  color: #3B82F6;
}

.save-card-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #64748B;
}

.comment-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.comment-empty text {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 16rpx;
}

.comment-input-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #F8FAFC;
  border-radius: 48rpx;
}

.comment-input {
  flex: 1;
  font-size: 28rpx;
  color: #1E293B;
  background: transparent;
  padding: 0 16rpx;
}

.comment-input::placeholder {
  color: #94A3B8;
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
}

.favorite-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #E2E8F0;
}

.favorite-btn-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #F8FAFC;
  font-size: 26rpx;
  color: #64748B;
  transition: all 0.2s ease;
}

.favorite-btn-inline.active {
  background: rgba(250, 173, 20, 0.1);
  color: #FAAD14;
}

.bottom-placeholder {
  height: 48rpx;
}

.study-nav-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 340rpx;
  z-index: 100;
}

.study-nav-bar.study-mode {
  background: linear-gradient(135deg, #f8faff 0%, #fff 100%);
}

.nav-btn-prev {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 16rpx 32rpx;
  border-radius: 48rpx;
  background: #F1F5F9;
  transition: all 0.2s ease;
}

.nav-btn-prev.disabled {
  opacity: 0.5;
}

.nav-btn-prev .prev-text {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #64748B;
  line-height: 36rpx;
  height: 36rpx;
  transform: translateY(-4rpx);
}

.nav-btn-next-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 16rpx 32rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
  transition: all 0.2s ease;
  transform: translateY(4rpx);
}

.nav-btn-next-card.disabled {
  background: #E2E8F0;
  box-shadow: none;
}

.nav-btn-next-card .next-text {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  line-height: 36rpx;
  height: 36rpx;
  transform: translateY(-4rpx);
  margin-left: 8rpx;
}

.nav-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;

  padding: 16rpx 32rpx;
  border-radius: 48rpx;
  background: #F1F5F9;
  transition: all 0.2s ease;
}

.nav-btn.disabled {
  opacity: 0.5;
}

.nav-btn.prev {
  background: rgba(59, 130, 246, 0.08);
  padding-left: 20rpx;
}

.nav-btn.next {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.2);
  padding-right: 20rpx;
}

.nav-btn .nav-text {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #3B82F6;
  line-height: 40rpx;
  height: 40rpx;
}

.nav-btn.next .nav-text {
  color: #fff;
}

.nav-btn-prev t-icon,
.nav-btn-next-card t-icon,
.nav-btn t-icon {
  display: flex;
  align-items: center;
}

.related-section {
  background: linear-gradient(135deg, #FFF8DC 0%, #FFFACD 50%, #FAFAD2 100%);
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(218, 165, 32, 0.2);
  border: 2rpx solid #D4AF37;
  animation: fadeIn 0.3s ease;
}

.related-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(212, 175, 55, 0.3);
}

.related-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.related-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #B8860B;
}

.related-vip-tag {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 600;
  margin-left: 8rpx;
}

.related-count {
  font-size: 26rpx;
  color: #C9A227;
}

.related-loading,
.related-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 16rpx;
}

.related-loading text,
.related-empty text {
  font-size: 26rpx;
  color: #C9A227;
}

.related-list {
  white-space: nowrap;
  margin: 0 -8rpx;
}

.related-item {
  display: inline-block;
  padding: 0 8rpx;
  vertical-align: top;
}

.related-card {
  width: 420rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #8cb6f9;
  transition: all 0.2s ease;
}

.related-card:active {
  transform: scale(0.98);
  border-color: #2563EB;
  background: #EFF6FF;
}

.related-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.related-card-library {
  font-size: 22rpx;
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-card-tags {
  display: flex;
  gap: 8rpx;
}

.related-tag {
  font-size: 20rpx;
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.related-card-question {
  min-height: 80rpx;
}

.related-card-question text {
  font-size: 26rpx;
  color: #1E293B;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  white-space: normal;
}

.related-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
}

.related-tip text {
  font-size: 22rpx;
  color: #C9A227;
}
