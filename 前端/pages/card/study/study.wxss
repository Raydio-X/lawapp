/* 全局容器 */
.study-container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding: 24rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* 模块一：题目展示区 */
.question-section {
  background: linear-gradient(135deg, #fff 0%, #f8faff 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 82, 217, 0.1);
  border: 2rpx solid rgba(0, 82, 217, 0.08);
}

.card-header {
  margin-bottom: 32rpx;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-number {
  font-size: 28rpx;
  color: #0052D9;
  font-weight: 600;
  background: rgba(0, 82, 217, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.card-tags {
  display: flex;
  gap: 12rpx;
}

.progress-bar {
  height: 8rpx;
  background-color: #e8e8e8;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0052D9 0%, #336FE3 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.question-content {
  padding: 24rpx 0;
}

.question-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.6;
  text-align: center;
}

/* 模块二：答案区域 */
.answer-section {
  background-color: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* 答案隐藏状态 */
.answer-hidden {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.reveal-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx 64rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.3);
  transition: all 0.2s ease;
}

.reveal-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 82, 217, 0.2);
}

/* 答案展开状态 */
.answer-revealed {
  padding: 32rpx;
  opacity: 0;
  transform: translateY(-20rpx);
  transition: all 0.4s ease;
}

.answer-revealed.show {
  opacity: 1;
  transform: translateY(0);
}

.answer-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #00B578;
}

.answer-content {
  background-color: #f8f9fa;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid #00B578;
}

.answer-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
}

/* 模块三：评论互动区 */
.comment-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.4s ease 0.2s;
}

.comment-section.show {
  opacity: 1;
  transform: translateY(0);
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.comment-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.comment-count {
  font-size: 26rpx;
  color: #999;
}

/* 评论列表 */
.comment-list {
  max-height: 400rpx;
  margin-bottom: 24rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f6fa;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.comment-avatar text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.comment-content {
  flex: 1;
}

.comment-user {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.username {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.comment-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.comment-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  background-color: #f5f6fa;
  transition: all 0.2s ease;
}

.like-btn:active {
  background-color: #e8e9eb;
}

.like-btn.liked {
  background-color: rgba(0, 82, 217, 0.1);
}

.like-btn text {
  font-size: 24rpx;
  color: #999;
}

.like-btn.liked text {
  color: #0052D9;
}

.save-card-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  background-color: #f5f6fa;
  transition: all 0.2s ease;
}

.save-card-btn:active {
  background-color: #e8e9eb;
}

.save-card-btn text {
  font-size: 24rpx;
  color: #999;
}

.comment-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  color: #999;
  font-size: 28rpx;
}

.comment-empty text {
  margin-top: 16rpx;
}

/* 评论输入框 */
.comment-input-section {
  display: flex;
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background-color: #f5f6fa;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #333;
}

.comment-input::placeholder {
  color: #999;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #f5f6fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
}

.send-btn:active {
  transform: scale(0.95);
}

/* 收藏按钮区域 */
.favorite-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.favorite-btn-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 0;
  border-radius: 36rpx;
  background-color: #f8f9fa;
  transition: all 0.25s ease;
}

.favorite-btn-inline text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

.favorite-btn-inline.active {
  background: linear-gradient(135deg, #fffbeb 0%, #fff7e6 100%);
}

.favorite-btn-inline.active text {
  color: #FAAD14;
  font-weight: 600;
}

.favorite-btn-inline:active {
  transform: scale(0.98);
}

/* 底部占位 */
.bottom-placeholder {
  height: 32rpx;
}

/* 模块四：学习导航栏 */
.study-nav-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #ffffff 0%, #fafbfc 100%);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.nav-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 22rpx 32rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border: 2rpx solid #e8ecf0;
  transition: all 0.25s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  white-space: nowrap;
  flex-shrink: 0;
}

.nav-text {
  font-size: 28rpx;
  color: #0052D9;
  font-weight: 600;
}

.nav-btn.disabled {
  background: #f5f5f5;
  border-color: #e8e8e8;
  box-shadow: none;
}

.nav-btn.disabled .nav-text {
  color: #ccc;
}

.nav-btn:not(.disabled):active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 82, 217, 0.15);
  background: linear-gradient(135deg, #eef2ff 0%, #f8f9fa 100%);
}

.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 0 32rpx;
}

/* 是否掌握按钮 */
.learned-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx 36rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border: 2rpx solid #e8ecf0;
  transition: all 0.25s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  white-space: nowrap;
  flex-shrink: 0;
}

.learned-text {
  font-size: 28rpx;
  color: #999;
  font-weight: 600;
}

.learned-btn.active {
  background: linear-gradient(135deg, #e6f7ef 0%, #f0fdf4 100%);
  border-color: #00B578;
  box-shadow: 0 4rpx 16rpx rgba(0, 181, 120, 0.2);
}

.learned-btn.active .learned-text {
  color: #00B578;
  font-weight: 600;
}

.learned-btn:active {
  transform: scale(0.96);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}
