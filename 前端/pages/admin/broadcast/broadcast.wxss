.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding: 32rpx;
}

.form-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.form-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.form-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.form-desc {
  font-size: 28rpx;
  color: #999;
}

.form-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-field {
  margin-bottom: 32rpx;
  position: relative;
}

.form-field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  background-color: #f5f6fa;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.field-input::placeholder {
  color: #bbb;
}

.field-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #333;
  background-color: #f5f6fa;
  border-radius: 12rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.field-textarea::placeholder {
  color: #bbb;
}

.field-count {
  position: absolute;
  right: 0;
  bottom: -32rpx;
  font-size: 24rpx;
  color: #bbb;
}

.form-tips {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx;
  background-color: #fff7e6;
  border-radius: 12rpx;
  margin-bottom: 48rpx;
}

.form-tips text {
  font-size: 26rpx;
  color: #fa8c16;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 16rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 44rpx;
}

.action-btn.cancel {
  background-color: #f5f6fa;
  color: #666;
}

.action-btn.confirm {
  background-color: #0052D9;
  color: #fff;
}

.action-btn.confirm:active {
  opacity: 0.8;
}
