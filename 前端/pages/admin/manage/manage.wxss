.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  z-index: 999;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #000;
}

.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.tab-bar {
  display: flex;
  background-color: #fff;
  padding: 16rpx 24rpx;
  gap: 8rpx;
  position: sticky;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-bar .tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #999;
  transition: all 0.2s;
}

.tab-bar .tab-item.active {
  color: #3B82F6;
  background-color: rgba(0, 82, 217, 0.06);
  font-weight: 500;
}

.content {
  padding: 24rpx 32rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.stat-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stat-icon.blue {
  background-color: rgba(0, 82, 217, 0.1);
}

.stat-icon.green {
  background-color: rgba(82, 196, 26, 0.1);
}

.stat-icon.orange {
  background-color: rgba(250, 140, 22, 0.1);
}

.stat-icon.red {
  background-color: rgba(245, 34, 45, 0.1);
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  color: #fff;
  padding: 0 28rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-chip {
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #fff;
  transition: all 0.2s;
}

.filter-chip.active {
  color: #3B82F6;
  background-color: rgba(0, 82, 217, 0.1);
  font-weight: 500;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.card-title-text {
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.meta-divider {
  font-size: 24rpx;
  color: #ddd;
}

.item-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.card-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.item-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.action-btn.edit {
  background-color: rgba(0, 82, 217, 0.08);
}

.action-btn.delete {
  background-color: rgba(245, 34, 45, 0.08);
}

.action-btn:active {
  transform: scale(0.9);
}

.comment-item .item-main {
  display: flex;
  flex-direction: column;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #bbb;
}

.comment-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.comment-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  color: #3B82F6;
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-batch-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  background-color: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
}

.empty-batch-tip text {
  color: #666;
  font-size: 28rpx;
}

.empty-batch-subtip {
  margin-top: 16rpx;
  color: #999;
  font-size: 24rpx;
}

.bottom-placeholder {
  height: 48rpx;
}

.admin-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  padding: 8rpx 0;
}

.tab-bar-text {
  font-size: 22rpx;
  color: #999;
}

.tab-bar-text.active-text {
  color: #3B82F6;
  font-weight: 500;
}

.edit-popup {
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  padding: 8rpx;
}

.popup-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.form-item.row {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.required {
  color: #f5222d;
}

.form-input {
  height: 80rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-textarea {
  min-height: 160rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.custom-switch {
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background-color: #ddd;
  position: relative;
  transition: all 0.3s;
}

.custom-switch.active {
  background-color: #3B82F6;
}

.custom-switch-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #fff;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: all 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.custom-switch.active .custom-switch-dot {
  left: 44rpx;
}

.popup-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #666;
  background-color: #f5f7fa;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  font-weight: 500;
}

.btn-cancel:active,
.btn-confirm:active {
  opacity: 0.9;
}

/* µē╣ķćÅµōŹõĮ£ÕĘźÕģĘµĀ?*/
.batch-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background-color: #fff;
  margin-bottom: 16rpx;
}

.batch-toggle-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.batch-toggle-btn.active {
  background-color: #e8f3ff;
  color: #3B82F6;
}

.batch-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-all-btn {
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.move-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background-color: #e8f3ff;
  font-size: 26rpx;
  color: #3B82F6;
}

.move-btn.disabled {
  background-color: #f5f5f5;
  color: #ccc;
}

.selected-count-bar {
  background-color: #e8f3ff;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  margin: 0 24rpx 16rpx;
  font-size: 26rpx;
  color: #3B82F6;
  text-align: center;
}

.list-item.selected {
  background-color: #e8f3ff !important;
  border: 2rpx solid #3B82F6 !important;
}

.card-item .item-main {
  display: flex;
  align-items: flex-start;
}

.select-checkbox {
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  padding-top: 8rpx;
}

.item-content {
  flex: 1;
}

/* ń½ĀĶŖéķĆēµŗ®Õ╝╣ń¬Ś */
.chapter-picker-popup {
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.chapter-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
}

.chapter-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.chapter-picker-close {
  padding: 8rpx;
}

.chapter-picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 0;
}

.chapter-picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #333;
}

.chapter-picker-item.selected {
  background-color: #e8f3ff;
  color: #3B82F6;
}

.chapter-picker-name {
  flex: 1;
  display: flex;
  align-items: center;
}

.chapter-level-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background-color: #e8f4ff;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.chapter-level-indicator text {
  font-size: 22rpx;
  color: #3B82F6;
  font-weight: 500;
}

.chapter-picker-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
}

.chapter-picker-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.chapter-picker-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.chapter-picker-btn.confirm {
  background-color: #3B82F6;
  color: #fff;
}

/* ńāŁķŚ©ÕŹĪńēćµĀĘÕ╝Å */
.hot-cards-header {
  padding: 16rpx 24rpx;
  background-color: #fffaf5;
  border-bottom: 1rpx solid #ffe8d6;
}

.hot-cards-tip {
  font-size: 24rpx;
  color: #ff6b35;
}

.hot-card-item .item-header {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.hot-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  border-radius: 16rpx;
  flex-shrink: 0;
}

.hot-badge text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.hot-stat {
  color: #ff6b35 !important;
  font-weight: 500;
}

/* µČłµü»ÕÅæÕĖāÕģźÕÅŻ */
.broadcast-entry {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.broadcast-entry:active {
  background-color: #f9f9f9;
}

.broadcast-entry-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: rgba(0, 82, 217, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.broadcast-entry-content {
  flex: 1;
}

.broadcast-entry-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.broadcast-entry-desc {
  font-size: 26rpx;
  color: #999;
}
