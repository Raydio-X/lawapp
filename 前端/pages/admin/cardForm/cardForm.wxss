.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: 240rpx;
  box-sizing: border-box;
}

.form-section {
  background-color: #fff;
  padding: 32rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-item.row .form-label {
  margin-bottom: 0;
}

.form-label-row {
  display: flex;
  flex-direction: column;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.label-required {
  font-size: 30rpx;
  color: #e34d59;
  margin-left: 8rpx;
}

.label-optional {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.form-label-row .label-optional {
  margin-left: 0;
  margin-top: 4rpx;
}

.picker-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
}

.picker-content {
  flex: 1;
  font-size: 30rpx;
  color: #999;
}

.picker-content.selected {
  color: #333;
}

.textarea-wrapper {
  position: relative;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  padding: 24rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

.answer-textarea {
  min-height: 240rpx;
}

.placeholder {
  font-size: 30rpx;
  color: #bbb;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.custom-switch {
  width: 80rpx;
  height: 44rpx;
  background-color: #ddd;
  border-radius: 22rpx;
  position: relative;
  padding: 4rpx;
  box-sizing: border-box;
}

.custom-switch.active {
  background-color: #3B82F6;
}

.custom-switch-dot {
  width: 36rpx;
  height: 36rpx;
  background-color: #fff;
  border-radius: 50%;
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}

.custom-switch.active .custom-switch-dot {
  left: 40rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn-group {
  display: flex;
  gap: 24rpx;
}

.btn-group t-button {
  flex: 1;
}

.tags-input-container {
  width: 100%;
}

.tags-list-horizontal {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tag-item-horizontal {
  display: flex;
  align-items: center;
  background-color: #f5f6fa;
  border-radius: 12rpx;
  padding: 0 8rpx 0 16rpx;
  height: 72rpx;
}

.tag-input-horizontal {
  width: 120rpx;
  height: 64rpx;
  font-size: 26rpx;
  color: #333;
  background: transparent;
}

.tag-remove-horizontal {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.tag-remove-horizontal:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.tag-add-btn-horizontal {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border: 2rpx dashed #ddd;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.tag-add-btn-horizontal:active {
  background-color: rgba(0, 82, 217, 0.04);
  border-color: #3B82F6;
}

.batch-import-entry {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #fff;
  margin-bottom: 16rpx;
  min-height: 10rpx;
}

.batch-import-text {
  flex: 1;
  font-size: 28rpx;
  color: #3B82F6;
  margin-left: 16rpx;
}

/* 批量导入弹窗 */
.batch-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.batch-container {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.batch-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.batch-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.batch-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  overflow: hidden;
}

.batch-step-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.batch-step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #3B82F6;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.batch-step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.batch-library-list {
  flex: 1;
  max-height: 400rpx;
}

.batch-library-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.batch-library-item.selected {
  border-color: #3B82F6;
  background: #f0f5ff;
}

.batch-library-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.batch-library-item.selected .batch-library-radio {
  border-color: #3B82F6;
}

.batch-radio-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #3B82F6;
}

.batch-library-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.batch-library-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.batch-library-count {
  font-size: 24rpx;
  color: #999;
}

.batch-empty {
  text-align: center;
  padding: 48rpx;
  color: #999;
  font-size: 28rpx;
}

.batch-upload-area {
  border: 2rpx dashed #ddd;
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  transition: all 0.2s;
}

.batch-upload-area:active {
  border-color: #00A870;
  background: #f8fdfb;
}

.batch-upload-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.batch-upload-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.batch-upload-hint {
  font-size: 24rpx;
  color: #999;
}

.batch-upload-done {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.batch-file-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.batch-file-change {
  font-size: 24rpx;
  color: #00A870;
}

.batch-template-section {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.batch-template-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.batch-template-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.batch-template-row {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.batch-template-row .col-a {
  width: 160rpx;
  color: #999;
}

.batch-template-row .col-b {
  color: #333;
  font-weight: 500;
}

.batch-download-template {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #3B82F6;
  border-radius: 12rpx;
  color: #3B82F6;
  font-size: 26rpx;
}

.batch-download-template:active {
  background: #f0f5ff;
}

.batch-step-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: auto;
  padding-top: 24rpx;
}

.batch-step-footer {
  display: flex;
  justify-content: center;
  margin-top: auto;
  padding-top: 24rpx;
}

.batch-prev-btn {
  flex: 0.5;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: #f5f5f5;
  color: #666;
}

.batch-prev-btn:active {
  background: #e8e8e8;
}

.batch-next-btn {
  flex: 0.5;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: #3B82F6;
  color: #fff;
}

.batch-next-btn.disabled {
  background: #ccc;
  color: #fff;
}

.batch-preview-summary {
  margin-bottom: 24rpx;
}

.batch-preview-total {
  font-size: 28rpx;
  color: #666;
}

.batch-preview-total .highlight {
  color: #3B82F6;
  font-weight: 600;
  font-size: 32rpx;
}

.batch-preview-list {
  flex: 1;
  max-height: 400rpx;
}

.batch-preview-item {
  display: flex;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.batch-preview-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8f4ff;
  color: #3B82F6;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.batch-preview-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.batch-preview-q {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.batch-preview-a {
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.batch-preview-chapter {
  font-size: 22rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

.batch-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0;
  gap: 24rpx;
}

.batch-result-icon {
  margin-bottom: 16rpx;
}

.batch-result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.batch-result-desc {
  font-size: 28rpx;
  color: #666;
}
