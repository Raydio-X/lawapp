.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  z-index: 999;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #000;
}

.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.search-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  position: sticky;
  z-index: 100;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f5f6fa;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 48rpx;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

.section {
  margin-top: 24rpx;
  background-color: #fff;
  padding: 32rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.more-link {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999;
  gap: 4rpx;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
}

.filter-tab {
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  background-color: #f5f6fa;
  transition: all 0.2s;
}

.filter-tab.active {
  color: #0052D9;
  background-color: rgba(0, 82, 217, 0.1);
  font-weight: 500;
}

.hot-cards-scroll {
  white-space: nowrap;
}

.hot-cards-list {
  display: flex;
  padding: 0 32rpx;
  gap: 16rpx;
}

.hot-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  width: 218rpx;
  height: 218rpx;
  background: linear-gradient(135deg, #fff 0%, #f8faff 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(0, 82, 217, 0.08);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.hot-card-content {
  flex: 1;
}

.hot-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  white-space: normal;
}

.hot-card-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hot-card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.like-count {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.like-count.liked {
  color: #0052D9;
  background-color: rgba(0, 82, 217, 0.1);
}

.library-section {
  padding-bottom: 48rpx;
}

.library-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 32rpx;
  gap: 24rpx;
}

.library-card {
  width: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.library-card-header {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.library-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, rgba(0, 82, 217, 0.1) 0%, rgba(0, 82, 217, 0.05) 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.library-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.library-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.library-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.library-card-footer {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  margin-left: 24rpx;
  padding-left: 24rpx;
  border-left: 2rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.stat-item.fav-stat {
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.stat-item.fav-stat.favorited {
  background-color: rgba(250, 173, 20, 0.1);
}

.stat-item.fav-stat.favorited .fav-text {
  color: #FAAD14;
}

.bottom-placeholder {
  height: 48rpx;
}

.admin-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  padding: 8rpx 0;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
}

.tab-text.active-text {
  color: #0052D9;
  font-weight: 500;
}
