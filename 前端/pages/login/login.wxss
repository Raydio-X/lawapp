.login-container {
  min-height: 100vh;
  background: linear-gradient(160deg, #f0f7ff 0%, #e8f4ff 50%, #f5f9ff 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse at 20% 20%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 80%, rgba(96, 165, 250, 0.06) 0%, transparent 50%);
}

/* 浮动卡片样式 */
.floating-card {
  position: absolute;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  box-shadow: 
    0 10rpx 40rpx rgba(59, 130, 246, 0.12),
    0 4rpx 12rpx rgba(59, 130, 246, 0.06);
  border: 1rpx solid rgba(59, 130, 246, 0.1);
  backdrop-filter: blur(4rpx);
}

.card-inner {
  padding: 24rpx 28rpx;
}

.card-line {
  height: 10rpx;
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.3) 0%, rgba(59, 130, 246, 0.1) 100%);
  border-radius: 5rpx;
  margin-bottom: 14rpx;
}

.card-line.short {
  width: 60%;
}

.card-line:last-child {
  margin-bottom: 0;
}

/* 上部区域卡片 - 较少 */
.card-2 {
  width: 110rpx;
  top: 14%;
  right: 6%;
  transform: rotate(12deg);
  animation: float2 10s ease-in-out infinite;
}

/* 下部区域卡片 - 较多 */
.bottom-decoration .card-3 {
  width: 145rpx;
  top: 17%;
  left: 6%;
  transform: rotate(5deg);
  animation: float3 9s ease-in-out infinite;
}

.bottom-decoration .card-4 {
  width: 120rpx;
  top: 27%;
  right: 8%;
  transform: rotate(-10deg);
  animation: float4 7s ease-in-out infinite;
}

.bottom-decoration .card-5 {
  width: 160rpx;
  top: 53%;
  left: 30%;
  transform: rotate(-5deg);
  animation: float5 11s ease-in-out infinite;
}

/* 浮动动画 */
@keyframes float2 {
  0%, 100% {
    transform: rotate(12deg) translateY(0);
  }
  50% {
    transform: rotate(12deg) translateY(-15rpx);
  }
}

@keyframes float3 {
  0%, 100% {
    transform: rotate(5deg) translateY(0);
  }
  50% {
    transform: rotate(5deg) translateY(-18rpx);
  }
}

@keyframes float4 {
  0%, 100% {
    transform: rotate(-10deg) translateY(0);
  }
  50% {
    transform: rotate(-10deg) translateY(-12rpx);
  }
}

@keyframes float5 {
  0%, 100% {
    transform: rotate(-5deg) translateY(0);
  }
  50% {
    transform: rotate(-5deg) translateY(-15rpx);
  }
}

/* 下部区域装饰 */
.bottom-decoration {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 45%;
  pointer-events: none;
  overflow: hidden;
}

.bottom-decoration .floating-card {
  position: absolute;
}

/* 装饰圆形 */
.circle {
  position: absolute;
  border-radius: 50%;
}

.circle-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.06) 0%, transparent 70%);
  top: -150rpx;
  right: -100rpx;
  animation: pulse 8s ease-in-out infinite;
}

.circle-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(96, 165, 250, 0.05) 0%, transparent 70%);
  bottom: -100rpx;
  left: -100rpx;
  animation: pulse 10s ease-in-out infinite;
  animation-delay: 2s;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.7;
  }
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
  margin-bottom: 60rpx;
  z-index: 1;
}

.logo-wrapper {
  margin-bottom: 32rpx;
}

.app-logo {
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.2);
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #64748B;
  letter-spacing: 2rpx;
}

.login-section {
  width: 100%;
  max-width: 640rpx;
  z-index: 1;
}

.login-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.08);
}

.login-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1E293B;
  text-align: center;
  margin-bottom: 12rpx;
}

.login-desc {
  display: block;
  font-size: 26rpx;
  color: #64748B;
  text-align: center;
  margin-bottom: 48rpx;
}

.wechat-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: #07c160;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 24rpx;
  padding: 0;
  transition: all 0.3s ease;
}

.wechat-login-btn.primary {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.wechat-login-btn .btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  margin-left: 16rpx;
}

.agreement-section {
  display: flex;
  align-items: center;
  margin-top: 48rpx;
  padding: 0 40rpx;
  z-index: 1;
  white-space: nowrap;
}

.checkbox-wrapper {
  margin-right: 12rpx;
  padding: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.agreement-text {
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.6;
}

.link {
  color: #3B82F6;
  font-weight: 500;
}

.agreement-popup {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.agreement-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.agreement-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.agreement-popup-content {
  padding: 32rpx;
  max-height: 600rpx;
  overflow-y: auto;
  font-size: 28rpx;
  color: #64748B;
  text-align: left;
  line-height: 1.8;
  white-space: pre-wrap;
}

.agreement-popup-footer {
  padding: 24rpx 32rpx;
  text-align: center;
  color: #3B82F6;
  font-size: 28rpx;
  font-weight: 500;
  border-top: 1rpx solid #E2E8F0;
}

.footer {
  margin-top: auto;
  padding-bottom: 40rpx;
  z-index: 1;
}

.version {
  font-size: 24rpx;
  color: #94A3B8;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #64748B;
}

.test-login-popup {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.test-login-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.test-login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
}

.test-login-form {
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #64748B;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1E293B;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #94A3B8;
}

.test-login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 44rpx;
  border: none;
  margin-top: 16rpx;
}

.test-login-btn::after {
  border: none;
}

.test-login-btn {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.test-login-btn:active {
  opacity: 0.9;
}
