<view class="login-container">
  <!-- 创意背景装饰 -->
  <view class="bg-decoration">
    <!-- 渐变背景 -->
    <view class="bg-gradient"></view>
    
    <!-- 浮动卡片 - 上部区域（1张） -->
    <view class="floating-card card-2">
      <view class="card-inner">
        <view class="card-line"></view>
        <view class="card-line short"></view>
      </view>
    </view>
    
    <!-- 装饰圆形 -->
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
  </view>

  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-wrapper">
      <t-avatar 
        class="app-logo"
        image="/assets/images/logo.png" 
        size="160rpx"
        shape="circle"
      />
    </view>
    <text class="app-name">法硕背诵助手</text>
    <text class="app-slogan">高效记忆 · 轻松备考</text>
  </view>

  <!-- 登录按钮区域 -->
  <view class="login-section">
    <view class="login-card">
      <text class="login-title">欢迎使用</text>
      <text class="login-desc">登录后即可使用完整功能</text>
      
      <!-- 微信一键登录按钮 -->
      <button 
        class="wechat-login-btn primary"
        bindtap="onWechatLoginNew"
      >
        <t-icon name="logo-wechat" size="48rpx" color="#fff" />
        <text class="btn-text">微信一键登录</text>
      </button>
    </view>
  </view>

  <!-- 用户协议 -->
  <view class="agreement-section">
    <view class="checkbox-wrapper" bindtap="toggleAgreement">
      <t-icon 
        name="{{hasAgreed ? 'check-circle-filled' : 'circle'}}" 
        size="32rpx" 
        color="{{hasAgreed ? '#3B82F6' : '#ccc'}}"
      />
    </view>
    <text class="agreement-text">登录即代表您同意<text class="link" bindtap="showUserAgreement">《用户协议》</text>和<text class="link" bindtap="showPrivacyPolicy">《隐私政策》</text></text>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="version" bind:longpress="showTestEntry">v1.0.0</text>
  </view>
  
  <!-- 下部区域装饰（登录按钮下方） -->
  <view class="bottom-decoration">
    <!-- 浮动卡片 - 下部区域（3张） -->
    <view class="floating-card card-3">
      <view class="card-inner">
        <view class="card-line"></view>
        <view class="card-line short"></view>
        <view class="card-line"></view>
      </view>
    </view>
    <view class="floating-card card-4">
      <view class="card-inner">
        <view class="card-line"></view>
        <view class="card-line short"></view>
      </view>
    </view>
    <view class="floating-card card-5">
      <view class="card-inner">
        <view class="card-line"></view>
        <view class="card-line short"></view>
        <view class="card-line"></view>
      </view>
    </view>
  </view>

  <!-- 加载提示 -->
  <t-toast id="t-toast" />
  
  <!-- 协议弹窗 -->
  <t-popup visible="{{showAgreementDialog}}" placement="center" bind:visible-change="closeAgreementDialog">
    <view class="agreement-popup">
      <view class="agreement-popup-header">
        <text class="agreement-popup-title">{{agreementTitle}}</text>
        <t-icon name="close" size="40rpx" color="#999" bind:tap="closeAgreementDialog" />
      </view>
      <view class="agreement-popup-content">{{agreementContent}}</view>
      <view class="agreement-popup-footer" bindtap="closeAgreementDialog">我知道了</view>
    </view>
  </t-popup>

  <!-- 测试登录弹窗 -->
  <t-popup visible="{{showTestLogin}}" placement="center">
    <view class="test-login-popup">
      <view class="test-login-header">
        <text class="test-login-title">测试入口</text>
        <t-icon name="close" size="40rpx" color="#999" bind:tap="closeTestLogin" />
      </view>
      <view class="test-login-form">
        <view class="form-item">
          <text class="form-label">账号</text>
          <input 
            class="form-input" 
            type="text" 
            placeholder="请输入测试账号"
            value="{{testAccount}}"
            bind:input="onTestAccountInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">密码</text>
          <input 
            class="form-input" 
            type="password" 
            placeholder="请输入测试密码"
            value="{{testPassword}}"
            bind:input="onTestPasswordInput"
          />
        </view>
        <button class="test-login-btn" bind:tap="onTestLogin">进入测试</button>
      </view>
    </view>
  </t-popup>
</view>
