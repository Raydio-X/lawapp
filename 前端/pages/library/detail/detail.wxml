<wxs module="utils">
var chineseNum = ['一', '二', '三', '四', '五', '六', '七', '八', '九', '十', 
                  '十一', '十二', '十三', '十四', '十五', '十六', '十七', '十八', '十九', '二十'];

module.exports = {
  getChapterNum: function(index) {
    return chineseNum[index] || (index + 1);
  },
  getSectionNum: function(chapterIndex, sectionIndex) {
    return (chapterIndex + 1) + '-' + (sectionIndex + 1);
  },
  getItemNum: function(chapterIndex, sectionIndex, itemIndex) {
    return (chapterIndex + 1) + '-' + (sectionIndex + 1) + '-' + (itemIndex + 1);
  }
}
</wxs>

<view class="container">
  <!-- 区域一：知识库概览卡片 -->
  <view class="library-overview-card">
    <view class="library-header">
      <view class="library-icon-large">
        <t-icon name="book" size="64rpx" color="#fff" />
      </view>
      <view class="library-info">
        <text class="library-name">{{libraryInfo.name}}</text>
        <view class="library-meta">
          <t-tag theme="primary" variant="light" size="small">{{libraryInfo.subject}}</t-tag>
          <text class="card-total">共 {{libraryInfo.totalCards}} 张卡片</text>
        </view>
      </view>
    </view>
    
    <!-- 学习进度 -->
    <view class="progress-section">
      <view class="progress-header">
        <text class="progress-label">学习进度</text>
        <text class="progress-percent">{{libraryInfo.progress}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-track">
          <view class="progress-fill" style="width: {{libraryInfo.progress}}%;"></view>
        </view>
      </view>
      <view class="progress-stats">
        <text>已学 {{libraryInfo.learnedCards}} / {{libraryInfo.totalCards}} 张</text>
      </view>
    </view>
  </view>

  <!-- 区域二：章节目录（树形缩进列表风格） -->
  <view class="catalog-section">
    <view class="catalog-header">
      <view class="catalog-title-row">
        <view class="catalog-title-icon">
          <t-icon name="view-list" size="36rpx" color="#3B82F6" />
        </view>
        <text class="catalog-title">章节目录</text>
      </view>
    </view>

    <view class="tree-list">
      <!-- 一级章节 -->
      <view 
        class="tree-node level-1 {{selectedChapterIndex === chapterIndex && selectedChildIndex === -1 && selectedGrandChildIndex === -1 ? 'active' : ''}}" 
        wx:for="{{chapters}}" 
        wx:key="id"
        wx:for-item="chapter"
        wx:for-index="chapterIndex"
      >
        <view class="tree-item" bindtap="onChapterTap" data-index="{{chapterIndex}}">
          <view class="tree-expand-icon" wx:if="{{chapter.children && chapter.children.length > 0}}">
            <t-icon name="{{chapter.expanded ? 'caret-down-small' : 'caret-right-small'}}" size="28rpx" color="#64748B" />
          </view>
          <view class="tree-expand-placeholder" wx:else></view>
          <view class="tree-content">
            <text class="tree-title">第{{utils.getChapterNum(chapterIndex)}}章 {{chapter.title}}</text>
            <view class="tree-meta">
              <view class="tree-progress-bar">
                <view class="tree-progress-fill" style="width: {{chapter.cards.length > 0 ? (chapter.learnedCount / chapter.cards.length * 100) : 0}}%;"></view>
              </view>
              <text class="tree-count">{{chapter.learnedCount}}/{{chapter.cards.length}}</text>
            </view>
          </view>
        </view>

        <!-- 二级章节 -->
        <view class="tree-children" wx:if="{{chapter.expanded && chapter.children && chapter.children.length > 0}}">
          <view 
            class="tree-node level-2 {{selectedChapterIndex === chapterIndex && selectedChildIndex === childIndex && selectedGrandChildIndex === -1 ? 'active' : ''}}"
            wx:for="{{chapter.children}}" 
            wx:for-item="childChapter"
            wx:for-index="childIndex"
            wx:key="id"
          >
            <view class="tree-item" bindtap="onChildChapterTap" data-chapter-index="{{chapterIndex}}" data-child-index="{{childIndex}}">
              <view class="tree-expand-icon small" wx:if="{{childChapter.children && childChapter.children.length > 0}}">
                <t-icon name="{{childChapter.expanded ? 'caret-down-small' : 'caret-right-small'}}" size="24rpx" color="#94A3B8" />
              </view>
              <view class="tree-expand-placeholder small" wx:else></view>
              <view class="tree-content">
                <text class="tree-title sub">{{utils.getSectionNum(chapterIndex, childIndex)}} {{childChapter.title}}</text>
                <text class="tree-count sub">{{childChapter.cards.length}}张</text>
              </view>
            </view>

            <!-- 三级章节 -->
            <view class="tree-children level-3" wx:if="{{childChapter.expanded && childChapter.children && childChapter.children.length > 0}}">
              <view 
                class="tree-node level-3 {{selectedChapterIndex === chapterIndex && selectedChildIndex === childIndex && selectedGrandChildIndex === grandChildIndex ? 'active' : ''}}"
                wx:for="{{childChapter.children}}" 
                wx:for-item="grandChildChapter"
                wx:for-index="grandChildIndex"
                wx:key="id"
              >
                <view class="tree-item" bindtap="onGrandChildChapterTap" data-chapter-index="{{chapterIndex}}" data-child-index="{{childIndex}}" data-grandchild-index="{{grandChildIndex}}">
                  <view class="tree-expand-placeholder small"></view>
                  <view class="tree-content">
                    <text class="tree-title sub-2">{{utils.getItemNum(chapterIndex, childIndex, grandChildIndex)}} {{grandChildChapter.title}}</text>
                    <text class="tree-count sub-2">{{grandChildChapter.cards.length}}张</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 区域三：选中章节的卡片列表 -->
  <view class="cards-section" id="cards-section" wx:if="{{selectedChapter}}">
    <view class="cards-header">
      <text class="cards-title">{{selectedChapter.title}}</text>
      <text class="cards-subtitle">
        共 {{selectedChapter.cards.length}} 张卡片
      </text>
    </view>

    <!-- 卡片列表 -->
    <view class="card-list-vertical">
      <view 
        class="card-item-large"
        wx:for="{{selectedChapter.cards}}" 
        wx:for-item="card"
        wx:for-index="cardIndex"
        wx:key="id"
        bindtap="onCardTap"
        data-index="{{cardIndex}}"
      >
        <view class="card-header">
          <view class="card-number-large">{{cardIndex + 1}}</view>
        </view>
        <view class="card-content-large">
          <text class="card-title-large">{{card.title}}</text>
          <view class="card-tags-large" wx:if="{{card.tags.length > 0}}">
            <t-tag 
              wx:for="{{card.tags}}" 
              wx:for-item="tag" 
              wx:key="*this"
              theme="primary" 
              variant="light"
              size="small"
            >{{tag}}</t-tag>
          </view>
        </view>
        <view class="card-arrow">
          <t-icon name="chevron-right" size="40rpx" color="#ccc" />
        </view>
      </view>
    </view>
  </view>

  <!-- 未选中章节时的提示 -->
  <view class="empty-tip" wx:if="{{!selectedChapter}}">
    <t-icon name="tips" size="80rpx" color="#ddd" />
    <text class="empty-text">请点击上方章节查看卡片</text>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>
</view>
