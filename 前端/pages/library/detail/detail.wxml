<view class="container">
  <!-- 区域一：知识库概览卡片 -->
  <view class="library-overview-card">
    <view class="library-header">
      <view class="library-icon-large">
        <t-icon name="folder" size="64rpx" color="#fff" />
      </view>
      <view class="library-info">
        <text class="library-name">{{libraryInfo.name}}</text>
        <view class="library-meta">
          <t-tag theme="primary" variant="light" size="small">{{libraryInfo.subject}}</t-tag>
          <text class="card-total">共 {{libraryInfo.totalCards}} 张卡片</text>
        </view>
      </view>
    </view>
    
    <!-- 学习进度 -->
    <view class="progress-section">
      <view class="progress-header">
        <text class="progress-label">学习进度</text>
        <text class="progress-percent">{{libraryInfo.progress}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-track">
          <view class="progress-fill" style="width: {{libraryInfo.progress}}%;"></view>
        </view>
      </view>
      <view class="progress-stats">
        <text>已学 {{libraryInfo.learnedCards}} / {{libraryInfo.totalCards}} 张</text>
      </view>
    </view>
  </view>

  <!-- 区域二：章节目录（时间线风格） -->
  <view class="catalog-section">
    <view class="catalog-header">
      <view class="catalog-title-row">
        <view class="catalog-title-icon">
          <t-icon name="view-list" size="36rpx" color="#0052D9" />
        </view>
        <text class="catalog-title">章节目录</text>
      </view>
    </view>

    <view class="chapter-timeline">
      <view 
        class="chapter-timeline-node {{item.expanded ? 'expanded' : ''}} {{selectedChapterIndex === chapterIndex && selectedChildIndex === -1 && selectedGrandChildIndex === -1 ? 'active' : ''}}" 
        wx:for="{{chapters}}" 
        wx:key="id"
        wx:for-item="chapter"
        wx:for-index="chapterIndex"
      >
        <view class="timeline-track">
          <view class="timeline-dot-wrap" bindtap="onChapterTap" data-index="{{chapterIndex}}">
            <view class="timeline-dot"></view>
          </view>
          <view class="timeline-line"></view>
        </view>

        <view class="timeline-content">
          <view 
            class="chapter-card {{selectedChapterIndex === chapterIndex && selectedChildIndex === -1 && selectedGrandChildIndex === -1 ? 'active' : ''}}"
            bindtap="onChapterTap"
            data-index="{{chapterIndex}}"
          >
            <view class="chapter-card-main">
              <view class="chapter-card-left">
                <text class="chapter-card-title">{{chapter.title}}</text>
              </view>
              <view class="chapter-card-right">
                <view class="chapter-progress-bar">
                  <view class="chapter-progress-fill" style="width: {{chapter.cards.length > 0 ? (chapter.learnedCount / chapter.cards.length * 100) : 0}}%;"></view>
                </view>
                <text class="chapter-card-progress-text">{{chapter.learnedCount}}/{{chapter.cards.length}}</text>
                <t-icon 
                  wx:if="{{chapter.children && chapter.children.length > 0}}"
                  name="{{chapter.expanded ? 'caret-up-small' : 'caret-down-small'}}" 
                  size="28rpx" 
                  color="#999" 
                />
              </view>
            </view>
          </view>

          <view class="section-timeline" wx:if="{{chapter.expanded && chapter.children && chapter.children.length > 0}}">
            <view 
              class="section-timeline-node {{selectedChapterIndex === chapterIndex && selectedChildIndex === childIndex && selectedGrandChildIndex === -1 ? 'active' : ''}}"
              wx:for="{{chapter.children}}" 
              wx:for-item="childChapter"
              wx:for-index="childIndex"
              wx:key="id"
            >
              <view class="section-track">
                <view class="section-dot-wrap">
                  <view class="section-dot"></view>
                </view>
                <view class="section-line"></view>
              </view>

              <view class="section-content">
                <view 
                  class="section-card {{selectedChapterIndex === chapterIndex && selectedChildIndex === childIndex && selectedGrandChildIndex === -1 ? 'active' : ''}}"
                  bindtap="onChildChapterTap"
                  data-chapter-index="{{chapterIndex}}"
                  data-child-index="{{childIndex}}"
                >
                  <text class="section-card-title">{{childChapter.title}}</text>
                  <view class="section-card-meta">
                    <text class="section-card-count">{{childChapter.cards.length}}张</text>
                    <t-icon 
                      wx:if="{{childChapter.children && childChapter.children.length > 0}}"
                      name="{{childChapter.expanded ? 'caret-up-small' : 'caret-down-small'}}" 
                      size="24rpx" 
                      color="#bbb" 
                    />
                  </view>
                </view>

                <view class="grandchild-list" wx:if="{{childChapter.expanded && childChapter.children && childChapter.children.length > 0}}">
                  <view 
                    class="grandchild-item {{selectedChapterIndex === chapterIndex && selectedChildIndex === childIndex && selectedGrandChildIndex === grandChildIndex ? 'active' : ''}}"
                    wx:for="{{childChapter.children}}" 
                    wx:for-item="grandChildChapter"
                    wx:for-index="grandChildIndex"
                    wx:key="id"
                    bindtap="onGrandChildChapterTap"
                    data-chapter-index="{{chapterIndex}}"
                    data-child-index="{{childIndex}}"
                    data-grandchild-index="{{grandChildIndex}}"
                  >
                    <view class="grandchild-dot"></view>
                    <text class="grandchild-title">{{grandChildChapter.title}}</text>
                    <text class="grandchild-count">{{grandChildChapter.cards.length}}张</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 区域三：选中章节的卡片列表 -->
  <view class="cards-section" wx:if="{{selectedChapter}}">
    <view class="cards-header">
      <text class="cards-title">{{selectedChapter.title}}</text>
      <text class="cards-subtitle">
        共 {{selectedChapter.cards.length}} 张卡片
      </text>
    </view>

    <!-- 卡片列表 -->
    <view class="card-list-vertical">
      <view 
        class="card-item-large"
        wx:for="{{selectedChapter.cards}}" 
        wx:for-item="card"
        wx:for-index="cardIndex"
        wx:key="id"
        bindtap="onCardTap"
        data-index="{{cardIndex}}"
      >
        <view class="card-header">
          <view class="card-number-large">{{cardIndex + 1}}</view>
        </view>
        <view class="card-content-large">
          <text class="card-title-large">{{card.title}}</text>
          <view class="card-tags-large" wx:if="{{card.tags.length > 0}}">
            <t-tag 
              wx:for="{{card.tags}}" 
              wx:for-item="tag" 
              wx:key="*this"
              theme="primary" 
              variant="light"
              size="small"
            >{{tag}}</t-tag>
          </view>
        </view>
        <view class="card-arrow">
          <t-icon name="chevron-right" size="40rpx" color="#ccc" />
        </view>
      </view>
    </view>
  </view>

  <!-- 未选中章节时的提示 -->
  <view class="empty-tip" wx:if="{{!selectedChapter}}">
    <t-icon name="tips" size="80rpx" color="#ddd" />
    <text class="empty-text">请点击上方章节查看卡片</text>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>
</view>
