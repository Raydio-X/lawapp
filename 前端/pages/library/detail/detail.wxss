.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding: 24rpx 28rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.library-overview-card {
  background: linear-gradient(135deg, #fff 0%, #f8faff 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.1);
  border: 2rpx solid rgba(59, 130, 246, 0.08);
}

.library-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.library-icon-large {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.library-info {
  flex: 1;
}

.library-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.library-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-total {
  font-size: 26rpx;
  color: #64748B;
}

.progress-section {
  background-color: rgba(59, 130, 246, 0.04);
  border-radius: 16rpx;
  padding: 24rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #64748B;
}

.progress-percent {
  font-size: 32rpx;
  font-weight: 700;
  color: #3B82F6;
}

.progress-bar {
  margin-bottom: 16rpx;
}

.progress-track {
  height: 12rpx;
  background-color: #E2E8F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-stats {
  font-size: 26rpx;
  color: #64748B;
}

.catalog-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.catalog-header {
  margin-bottom: 28rpx;
}

.catalog-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.catalog-title-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8f4ff 0%, #d6e8ff 100%);
  border-radius: 14rpx;
}

.catalog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.chapter-timeline {
  display: flex;
  flex-direction: column;
}

.chapter-timeline-node {
  display: flex;
}

.timeline-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
  padding-top: 22rpx;
}

.timeline-dot-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #d0d5dd;
  border: 4rpx solid #fff;
  transition: all 0.3s ease;
  box-shadow: 0 0 0 2rpx #eef1f5;
}

.chapter-timeline-node.active .timeline-dot {
  background-color: #3B82F6;
  border-color: #fff;
  box-shadow: 0 0 0 2rpx rgba(59, 130, 246, 0.2), 0 0 0 6rpx rgba(59, 130, 246, 0.1);
}

.timeline-line {
  flex: 1;
  width: 2rpx;
  background: linear-gradient(to bottom, #d0d5dd, #e8eaed);
  margin: -4rpx 0;
}

.chapter-timeline-node:last-child .timeline-line {
  display: none;
}

.timeline-content {
  flex: 1;
  padding-bottom: 24rpx;
  padding-top: 10rpx;
  min-width: 0;
}

.chapter-card {
  background-color: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.chapter-card:active {
  background-color: #f0f2f5;
}

.chapter-card.active {
  background-color: #fff;
  border-color: rgba(59, 130, 246, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.1);
}

.chapter-card-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.chapter-card-left {
  flex: 1;
  min-width: 0;
}

.chapter-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chapter-card.active .chapter-card-title {
  color: #3B82F6;
}

.chapter-card-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.chapter-progress-bar {
  width: 80rpx;
  height: 8rpx;
  background-color: #E2E8F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.chapter-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6, #60A5FA);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.chapter-card-progress-text {
  font-size: 22rpx;
  color: #64748B;
  min-width: 60rpx;
  text-align: right;
}

.chapter-card.active .chapter-card-progress-text {
  color: #3B82F6;
}

.section-timeline {
  display: flex;
  flex-direction: column;
  margin-top: 8rpx;
}

.section-timeline-node {
  display: flex;
}

.section-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 36rpx;
  flex-shrink: 0;
  padding-left: 8rpx;
  padding-top: 16rpx;
}

.section-dot-wrap {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}

.section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #d0d5dd;
  border: 3rpx solid #fff;
  transition: all 0.3s ease;
  box-shadow: 0 0 0 1rpx #e8eaed;
}

.section-timeline-node.active .section-dot {
  background-color: #3B82F6;
  border-color: #fff;
  box-shadow: 0 0 0 1rpx rgba(59, 130, 246, 0.2), 0 0 0 4rpx rgba(59, 130, 246, 0.1);
}

.section-line {
  flex: 1;
  width: 2rpx;
  background: linear-gradient(to bottom, #d0d5dd, #e8eaed);
  margin: -2rpx 0;
}

.section-timeline-node:last-child .section-line {
  display: none;
}

.section-content {
  flex: 1;
  padding-bottom: 8rpx;
  padding-top: 6rpx;
  min-width: 0;
}

.section-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  gap: 12rpx;
}

.section-card:active {
  background-color: #F8FAFC;
}

.section-card.active {
  background-color: rgba(59, 130, 246, 0.06);
}

.section-card-title {
  flex: 1;
  font-size: 28rpx;
  color: #64748B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-card.active .section-card-title {
  color: #3B82F6;
  font-weight: 500;
}

.section-card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.section-card-count {
  font-size: 22rpx;
  color: #94A3B8;
}

.section-card.active .section-card-count {
  color: #3B82F6;
}

.grandchild-list {
  padding-left: 16rpx;
  margin-top: 4rpx;
}

.grandchild-item {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  gap: 10rpx;
  transition: background-color 0.2s ease;
}

.grandchild-item:active {
  background-color: #F8FAFC;
}

.grandchild-item.active {
  background-color: rgba(59, 130, 246, 0.05);
}

.grandchild-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background-color: #d5d8dc;
  flex-shrink: 0;
}

.grandchild-item.active .grandchild-dot {
  background-color: #3B82F6;
}

.grandchild-title {
  flex: 1;
  font-size: 26rpx;
  color: #64748B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.grandchild-item.active .grandchild-title {
  color: #3B82F6;
}

.grandchild-count {
  font-size: 22rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.grandchild-item.active .grandchild-count {
  color: #3B82F6;
}

.cards-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cards-header {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #E2E8F0;
}

.cards-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.cards-subtitle {
  font-size: 26rpx;
  color: #64748B;
}

.card-list-vertical {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-item-large {
  display: flex;
  align-items: center;
  background-color: #F8FAFC;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
}

.card-item-large:active {
  background-color: #e8e9ea;
  transform: scale(0.99);
}

.card-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
}

.card-number-large {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.card-content-large {
  flex: 1;
  min-width: 0;
}

.card-title-large {
  display: block;
  font-size: 30rpx;
  color: #1E293B;
  margin-bottom: 12rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-tags-large {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.card-arrow {
  margin-left: 20rpx;
  flex-shrink: 0;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.empty-text {
  font-size: 28rpx;
  color: #64748B;
  margin-top: 24rpx;
}

.bottom-placeholder {
  height: 48rpx;
}
