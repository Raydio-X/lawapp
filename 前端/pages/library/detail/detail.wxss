/* 全局容器 */
.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding: 24rpx 32rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* 区域一：知识库概览卡片 */
.library-overview-card {
  background: linear-gradient(135deg, #fff 0%, #f8faff 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 82, 217, 0.1);
  border: 2rpx solid rgba(0, 82, 217, 0.08);
}

.library-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.library-icon-large {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.3);
}

.library-info {
  flex: 1;
}

.library-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.library-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-total {
  font-size: 26rpx;
  color: #999;
}

/* 学习进度 */
.progress-section {
  background-color: rgba(0, 82, 217, 0.04);
  border-radius: 16rpx;
  padding: 24rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #666;
}

.progress-percent {
  font-size: 32rpx;
  font-weight: 700;
  color: #0052D9;
}

.progress-bar {
  margin-bottom: 16rpx;
}

.progress-track {
  height: 12rpx;
  background-color: #e8e8e8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0052D9 0%, #336FE3 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  color: #999;
}

.continue-btn {
  color: #0052D9;
  font-weight: 500;
  padding: 8rpx 16rpx;
  background-color: rgba(0, 82, 217, 0.1);
  border-radius: 8rpx;
}

.continue-btn:active {
  background-color: rgba(0, 82, 217, 0.2);
}

/* 区域二：章节目录（树形结构） */
.catalog-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.catalog-header {
  margin-bottom: 24rpx;
}

.catalog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 章节树形列表 */
.chapter-tree {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.chapter-tree-item {
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.chapter-tree-item.expanded {
  border-color: rgba(0, 82, 217, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(0, 82, 217, 0.08);
}

/* 一级章节标题 */
.chapter-tree-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background-color: #f8f9fa;
}

.chapter-tree-header.active {
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
}

.chapter-tree-header:active {
  opacity: 0.9;
}

.chapter-tree-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.chapter-tree-placeholder {
  width: 36rpx;
  height: 36rpx;
}

.chapter-tree-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.chapter-tree-header.active .chapter-tree-title {
  color: #fff;
}

.chapter-tree-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chapter-tree-count {
  font-size: 24rpx;
  color: #999;
  background-color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.chapter-tree-header.active .chapter-tree-count {
  color: #0052D9;
}

.chapter-tree-progress {
  font-size: 24rpx;
  color: #0052D9;
  background-color: rgba(0, 82, 217, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.chapter-tree-header.active .chapter-tree-progress {
  color: #fff;
  background-color: rgba(255, 255, 255, 0.2);
}

/* 二级小节列表 */
.section-tree-list {
  background-color: #fff;
  padding: 16rpx 0;
}

.section-tree-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 20rpx 56rpx;
  border-left: 4rpx solid transparent;
}

.section-tree-item:active {
  background-color: #f5f6fa;
}

.section-tree-item.active {
  background-color: rgba(0, 82, 217, 0.06);
  border-left-color: #0052D9;
}

.section-tree-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #ccc;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-tree-item.active .section-tree-dot {
  background-color: #0052D9;
}

.section-tree-title-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.section-tree-item.active .section-tree-title-text {
  color: #0052D9;
  font-weight: 500;
}

.section-tree-count {
  font-size: 24rpx;
  color: #999;
}

.section-tree-item.active .section-tree-count {
  color: #0052D9;
}

.section-tree-header {
  display: flex;
  align-items: center;
  flex: 1;
}

/* 三级孙子章节列表 */
.grandchild-tree-list {
  background-color: #fafbfc;
  padding: 8rpx 0;
}

.grandchild-tree-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 16rpx 88rpx;
  border-left: 4rpx solid transparent;
}

.grandchild-tree-item:active {
  background-color: #f0f1f5;
}

.grandchild-tree-item.active {
  background-color: rgba(0, 82, 217, 0.06);
  border-left-color: #0052D9;
}

.grandchild-tree-dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #ddd;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.grandchild-tree-item.active .grandchild-tree-dot {
  background-color: #0052D9;
}

.grandchild-tree-title-text {
  flex: 1;
  font-size: 26rpx;
  color: #888;
}

.grandchild-tree-item.active .grandchild-tree-title-text {
  color: #0052D9;
  font-weight: 500;
}

.grandchild-tree-count {
  font-size: 22rpx;
  color: #aaa;
}

.grandchild-tree-item.active .grandchild-tree-count {
  color: #0052D9;
}

/* 区域三：卡片列表 */
.cards-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cards-header {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.cards-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.cards-subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 卡片列表 */
.card-list-vertical {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-item-large {
  display: flex;
  align-items: center;
  background-color: #f8f9fa;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
}

.card-item-large:active {
  background-color: #e8e9ea;
  transform: scale(0.99);
}

.card-item-large.learned {
  border-color: rgba(0, 181, 120, 0.2);
  background-color: rgba(0, 181, 120, 0.04);
}

.card-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
}

.card-number-large {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.card-status-icon {
  margin-top: 4rpx;
}

.card-content-large {
  flex: 1;
  min-width: 0;
}

.card-title-large {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-tags-large {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.card-arrow {
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 空提示 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 底部占位 */
.bottom-placeholder {
  height: 48rpx;
}

/* 底部固定操作栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.action-btn.primary {
  background: linear-gradient(135deg, #0052D9 0%, #336FE3 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.3);
}

.action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 82, 217, 0.2);
}

.action-btn.secondary {
  background-color: #f5f6fa;
  color: #0052D9;
  border: 2rpx solid rgba(0, 82, 217, 0.2);
}

.action-btn.secondary:active {
  background-color: rgba(0, 82, 217, 0.1);
}
