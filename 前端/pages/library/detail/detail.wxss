.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding: 24rpx 28rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.library-overview-card {
  background: linear-gradient(135deg, #fff 0%, #f8faff 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.1);
  border: 2rpx solid rgba(59, 130, 246, 0.08);
}

.library-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.library-icon-large {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.library-info {
  flex: 1;
}

.library-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.library-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-total {
  font-size: 26rpx;
  color: #64748B;
}

.progress-section {
  background-color: rgba(59, 130, 246, 0.04);
  border-radius: 16rpx;
  padding: 24rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #64748B;
}

.progress-percent {
  font-size: 32rpx;
  font-weight: 700;
  color: #3B82F6;
}

.progress-bar {
  margin-bottom: 16rpx;
}

.progress-track {
  height: 12rpx;
  background-color: #E2E8F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-stats {
  font-size: 26rpx;
  color: #64748B;
}

.catalog-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.catalog-header {
  margin-bottom: 28rpx;
}

.catalog-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.catalog-title-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8f4ff 0%, #d6e8ff 100%);
  border-radius: 14rpx;
}

.catalog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.tree-list {
  display: flex;
  flex-direction: column;
}

.tree-node {
  display: flex;
  flex-direction: column;
}

.tree-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  gap: 12rpx;
  position: relative;
}

.tree-item:active {
  background-color: #F8FAFC;
}

.tree-node.active > .tree-item {
  background-color: rgba(59, 130, 246, 0.08);
}

.tree-expand-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.2s ease;
}

.tree-expand-icon.small {
  width: 28rpx;
  height: 28rpx;
}

.tree-expand-placeholder {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.tree-expand-placeholder.small {
  width: 28rpx;
  height: 28rpx;
}

.tree-content {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.tree-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tree-title.sub {
  font-size: 28rpx;
  font-weight: 500;
  color: #475569;
}

.tree-title.sub-2 {
  font-size: 26rpx;
  font-weight: 400;
  color: #64748B;
}

.tree-node.active .tree-title {
  color: #3B82F6;
}

.tree-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.tree-progress-bar {
  width: 60rpx;
  height: 6rpx;
  background-color: #E2E8F0;
  border-radius: 3rpx;
  overflow: hidden;
}

.tree-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6, #60A5FA);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

.tree-count {
  font-size: 24rpx;
  color: #64748B;
  min-width: 60rpx;
  text-align: right;
}

.tree-count.sub {
  font-size: 22rpx;
  color: #94A3B8;
}

.tree-count.sub-2 {
  font-size: 20rpx;
  color: #94A3B8;
}

.tree-node.active .tree-count {
  color: #3B82F6;
}

.tree-children {
  padding-left: 32rpx;
  position: relative;
}

.tree-children.level-3 {
  padding-left: 32rpx;
}

.tree-node.level-2 .tree-item {
  padding: 16rpx 12rpx;
}

.tree-node.level-3 .tree-item {
  padding: 12rpx 10rpx;
}

.cards-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cards-header {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #E2E8F0;
}

.cards-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.cards-subtitle {
  font-size: 26rpx;
  color: #64748B;
}

.card-list-vertical {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-item-large {
  display: flex;
  align-items: center;
  background-color: #F8FAFC;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
}

.card-item-large:active {
  background-color: #e8e9ea;
  transform: scale(0.99);
}

.card-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
}

.card-number-large {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.card-content-large {
  flex: 1;
  min-width: 0;
}

.card-title-large {
  display: block;
  font-size: 30rpx;
  color: #1E293B;
  margin-bottom: 12rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-tags-large {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.card-arrow {
  margin-left: 20rpx;
  flex-shrink: 0;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.empty-text {
  font-size: 28rpx;
  color: #64748B;
  margin-top: 24rpx;
}

.bottom-placeholder {
  height: 48rpx;
}
